@using Microsoft.AspNetCore.Http
@using ElectoMarket.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext _context

@{
    // 🧠 Lógica Global de Sesión
    var uId = Context.Session.GetInt32("UsuarioId");
    var uNombre = Context.Session.GetString("UsuarioNombre") ?? "Invitado";
    var uFoto = Context.Session.GetString("UsuarioFoto");
    
    // 🔴 Contador de Mensajes (Funciona en todo el sitio)
    int mensajesSinLeer = 0;
    if (uId != null) {
        mensajesSinLeer = _context.Mensajes.Include(m => m.Chat)
            .Count(m => !m.Leido && m.RemitenteId != uId && (m.Chat.Usuario1Id == uId || m.Chat.Usuario2Id == uId));
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ElectroMarket</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    
    <style>
        :root {
            --bg-main: #0f0f10;
            --bg-nav: #161618;
            --bg-card: #1c1c1f;
            --border-tech: rgba(255, 255, 255, 0.1);
            --cyan-neon: #00d2ff;
            --green-neon: #00ff88;
            --morado: #7c4dff;
            --morado-glow: rgba(124, 77, 255, 0.2);
        }

        body { background-color: var(--bg-main); color: white; font-family: 'Inter', sans-serif; margin: 0; }
        
        .navbar-main { 
            background-color: rgba(10, 10, 12, 0.9); 
            backdrop-filter: blur(15px); 
            border-bottom: 1px solid var(--border-tech); 
            padding: 12px 0; 
        }

        .btn-navbar { 
            border-radius: 50px; padding: 6px 20px; font-size: 0.8rem; font-weight: bold; 
            text-transform: uppercase; transition: 0.3s; text-decoration: none; display: inline-block;
        }
        .btn-login { background: transparent; color: white; border: 1px solid rgba(255,255,255,0.2); }
        .btn-login:hover { background: rgba(255,255,255,0.05); color: white; border-color: white; }
        
        .btn-register { background: linear-gradient(135deg, var(--green-neon), #00cc6e); color: black; border: none; }
        .btn-register:hover { box-shadow: 0 0 15px var(--green-neon); transform: translateY(-2px); color: black; }
        
        .hover-white:hover { color: white !important; transition: 0.2s; }
        
        .profile-link:hover img { border-color: var(--cyan-neon) !important; box-shadow: 0 0 10px var(--cyan-neon); }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <nav class="navbar-main sticky-top z-3">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none d-flex align-items-center">
                    <img src="/imagenes/Logo/Logo.jpg" style="height: 40px; border-radius: 50%;">
                    <span class="text-white fw-bold ms-2 fs-5">ElectroMarket</span>
                </a>
                <div class="ms-5 d-flex gap-4">
                    <a asp-controller="Productos" asp-action="Index" class="text-white-50 text-decoration-none small fw-bold hover-white">Catálogo</a>
                    <a asp-controller="Comparacion" asp-action="Index" class="text-white-50 text-decoration-none small fw-bold hover-white">Versus Tech</a>
                    <a asp-controller="Guias" asp-action="Index" class="text-white fw-bold small" style="color: var(--green-neon) !important;">Tutoriales</a>
                </div>
            </div>

            <div class="d-flex align-items-center gap-4">
                @if (uId != null) {
                    <a asp-controller="Chats" asp-action="Index" class="text-white position-relative fs-5 hover-white">
                        <i class="bi bi-chat-dots"></i>
                        @if (mensajesSinLeer > 0) { 
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">@mensajesSinLeer</span> 
                        }
                    </a>
                    <a asp-controller="Usuarios" asp-action="Perfil" class="text-decoration-none d-flex align-items-center profile-link">
                        <img src="@(!string.IsNullOrEmpty(uFoto) ? uFoto : "/imagenes/placeholder-perfil.png")" style="width: 38px; height: 38px; object-fit: cover;" class="rounded-circle border border-secondary me-2">
                        <div class="d-flex flex-column text-start me-2">
                            <span class="text-white-50" style="font-size: 0.6rem;">Hola,</span>
                            <span class="text-white small fw-bold" style="line-height: 1;">@uNombre</span>
                        </div>
                    </a>
                    <form asp-controller="Usuarios" asp-action="Logout" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">Salir</button>
                    </form>
                } else {
                    <a asp-controller="Usuarios" asp-action="Login" class="btn-navbar btn-login">Iniciar Sesión</a>
                    <a asp-controller="Usuarios" asp-action="Register" class="btn-navbar btn-register">Registrarse</a>
                }
            </div>
        </div>
    </nav>

    <div class="container-fluid p-0">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>