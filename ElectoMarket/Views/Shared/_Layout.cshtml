@using Microsoft.AspNetCore.Http

@{    
    // 🟢 Leemos la sesión directamente de forma segura
    var uId = Context.Session.GetInt32("UsuarioId");
    var uNombre = Context.Session.GetString("UsuarioNombre");
    var uFoto = Context.Session.GetString("UsuarioFoto");
    var uRol = Context.Session.GetInt32("UsuarioRol"); // 🛡️ 1 = Admin, 2 = Usuario normal
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ElectroMarket</title>
    
    @* Librerías y Estilos *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        .btn-morado { background-color: #6f2dbd; color: white; border: none; }
        .btn-morado:hover { background-color: #5936a2; color: white; }
        .hover-zoom:hover { transform: scale(1.1); transition: 0.2s; }
        /* Efecto de brillo suave para el nombre del Admin */
        .admin-glow { text-shadow: 0 0 5px rgba(255, 193, 7, 0.3); }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3">
            <div class="container">
                
                @* 🟢 AQUÍ ENTRA EL LOGO REDONDEADO *@
                <a asp-controller="Home" asp-action="Index" class="navbar-brand d-flex align-items-center text-decoration-none">
                    <img src="/imagenes/Logo/Logo.jpg" alt="Logo" style="height: 40px; width: 40px; border-radius: 50%; background-color: white; object-fit: contain;">
                    
                    @* Ojo: Le dejé el color primario (azul/morado) al texto para que haga juego con el diseño claro que tienes en esta página *@
                    <span class="fw-bold text-primary fs-5">ElectroMarket</span>
                </a>
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @* --- SECCIÓN IZQUIERDA DEL MENÚ --- *@
                    <ul class="navbar-nav flex-grow-1 ms-3">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Productos" asp-action="Index">Catálogo</a>
                        </li>
                        
                        @* 🛡️ BOTONES SECRETOS PARA EL ADMIN *@
                        @if (uRol == 1)
                        {
                            @* 1. Gestión de Productos *@
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold" asp-controller="Productos" asp-action="Gestionar">
                                    <i class="bi bi-shield-lock-fill"></i> Panel Admin
                                </a>
                            </li>
                            
                            @* 2. Gestión de Usuarios *@
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold" asp-controller="Usuarios" asp-action="ListadoUsuarios">
                                    <i class="bi bi-person-gear"></i> Gestionar Usuarios
                                </a>
                            </li>
                        }
                    </ul>

                    @* --- SECCIÓN DERECHA DEL MENÚ (PERFIL Y LOGIN) --- *@
                    <div class="d-flex align-items-center">
                        @if (uId != null)
                        {                            
                            // 🟢 SI EL USUARIO INICIÓ SESIÓN                                                        
                            
                            // 💬 ICONO DE CHAT                            
                            <a class="text-dark position-relative hover-zoom me-4" asp-controller="Chats" asp-action="Index" title="Mis Mensajes">
                                <i class="bi bi-chat-dots fs-4"></i>
                                <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle" style="margin-top: 5px; margin-left: -5px;">
                                    <span class="visually-hidden">Mensajes</span>
                                </span>
                            </a>                            
                            
                            // 👤 FOTO, NOMBRE Y ROL DE ADMIN                            
                            <a asp-controller="Usuarios" asp-action="Perfil" class="text-decoration-none text-dark d-flex align-items-center me-3 hover-zoom">
                                <img src="@(!string.IsNullOrEmpty(uFoto) ? uFoto : "/imagenes/placeholder-perfil.png")" 
                                     class="rounded-circle object-fit-cover shadow-sm border" 
                                     style="width: 35px; height: 35px; margin-right: 8px;" alt="Foto" />
                                
                                <span>
                                    Hola, <strong>@uNombre</strong>
                                    @if (uRol == 1)
                                    {
                                        <span class="text-warning fw-bold admin-glow ms-1" style="font-size: 0.9rem;">
                                            <i class="bi bi-shield-lock-fill"></i> (Admin)
                                        </span>
                                    }
                                </span>
                            </a>                            
                            
                            // 🚪 BOTÓN DE SALIR                            
                            <form asp-controller="Usuarios" asp-action="Logout" method="post" class="m-0 p-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger rounded-pill fw-bold btn-sm px-3 shadow-sm">
                                    Salir
                                </button>
                            </form>
                        }
                        else
                        {                            
                            // 🔴 SI NO HA INICIADO SESIÓN (Visitante)                            
                            <a asp-controller="Usuarios" asp-action="Login" class="btn btn-outline-dark px-4 shadow-sm me-2 rounded-pill fw-bold">
                                Ingresar
                            </a>
                            <a asp-controller="Usuarios" asp-action="Register" class="btn btn-morado px-4 shadow-sm rounded-pill fw-bold">
                                Registrarse
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* Scripts Básicos *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* 🟢 SCRIPT DETECTOR DE AFK (Solo se carga si el usuario está logueado) 🟢 *@
    @if (uId != null)
    {
        <script>
            // 30 minutos expresados en milisegundos
            const limiteAFK = 30 * 60 * 1000; 

            // Esta función actualiza la "hora de vida" cada vez que el usuario hace algo
            function actualizarActividad() {
                localStorage.setItem('ultimaActividad', Date.now());
            }

            // Escuchamos los movimientos del usuario
            window.onload = actualizarActividad;
            document.onmousemove = actualizarActividad;
            document.onkeypress = actualizarActividad;
            document.onclick = actualizarActividad;
            document.ontouchstart = actualizarActividad; // Por si entran desde el celular

            // El sistema revisa silenciosamente cada 10 segundos si el usuario sigue vivo
            setInterval(() => {
                const ultimaActividad = localStorage.getItem('ultimaActividad');
                
                // Si hay un registro y la diferencia de tiempo es mayor a 30 minutos...
                if (ultimaActividad && (Date.now() - ultimaActividad > limiteAFK)) {
                    localStorage.removeItem('ultimaActividad'); // Limpiamos para evitar un bucle infinito
                    window.location.href = '/Usuarios/LogoutAFK'; // ¡Expulsado al Login!
                }
            }, 10000); 
        </script>
    }
</body>
</html>
