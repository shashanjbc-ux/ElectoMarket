@model ElectoMarket.Models.Producto
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    Layout = null;
    var uId = HttpContextAccessor.HttpContext?.Session.GetInt32("UsuarioId");
    var uNombre = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioNombre") ?? "Usuario";
    var uFoto = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioFoto");
    var miRol = Context.Session.GetInt32("UsuarioRol");
    bool esAdmin = miRol == 1;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Editar @Model?.Nombre - ElectroMarket</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
            :root {
                --bg-main: #08080a;
                --bg-card: rgba(18, 18, 20, 0.75);
                --border-color: rgba(255, 255, 255, 0.1);
                --text-main: #ffffff;
                --text-muted: #a1a1aa;
                --morado: #7c4dff;
                --cyan-neon: #00d2ff;
            }

            body {
                background-color: var(--bg-main);
                color: var(--text-main);
                font-family: 'Inter', system-ui, sans-serif;
                margin: 0;
                min-height: 100vh;
            }

            .tech-bg {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                z-index: -1;
                background-image: radial-gradient(circle at 10% 20%, rgba(124, 77, 255, 0.08) 0%, transparent 40%), radial-gradient(circle at 90% 80%, rgba(0, 210, 255, 0.08) 0%, transparent 40%);
            }

            .navbar-main {
                background-color: rgba(10, 10, 12, 0.9);
                backdrop-filter: blur(15px);
                border-bottom: 1px solid var(--border-color);
                padding: 12px 0;
            }

            /* ESTILOS DEL FORMULARIO  */
            .form-card {
                background: var(--bg-card);
                backdrop-filter: blur(25px);
                border: 1px solid var(--border-color);
                border-radius: 20px;
                padding: 40px;
                box-shadow: 0 20px 50px rgba(0,0,0,0.5);
                max-width: 800px;
                margin: 40px auto;
            }

            .form-label-tech {
                color: var(--cyan-neon);
                font-weight: 600;
                font-size: 0.9rem;
                text-transform: uppercase;
                letter-spacing: 1px;
                margin-bottom: 8px;
                display: block;
            }

            .form-control-tech {
                background: rgba(0,0,0,0.5);
                border: 1px solid var(--border-color);
                color: white;
                border-radius: 12px;
                padding: 12px 15px;
                transition: 0.3s;
            }

                .form-control-tech:focus {
                    background: rgba(0,0,0,0.8);
                    border-color: var(--cyan-neon);
                    box-shadow: 0 0 15px rgba(0, 210, 255, 0.2);
                    color: white;
                    outline: none;
                }

            .form-check-input:checked {
                background-color: #ffc107;
                border-color: #ffc107;
            }

            .btn-save {
                background: linear-gradient(135deg, var(--morado), var(--cyan-neon));
                color: white;
                border: none;
                border-radius: 12px;
                padding: 14px 25px;
                font-weight: 700;
                width: 100%;
                transition: 0.3s;
                display: flex;
                justify-content: center;
                align-items: center;
            }

                .btn-save:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 10px 20px rgba(124, 77, 255, 0.4);
                    color: white;
                }

            .btn-cancel {
                background: transparent;
                border: 1px solid var(--border-color);
                color: var(--text-muted);
                border-radius: 12px;
                padding: 14px 25px;
                font-weight: 600;
                text-decoration: none;
                display: flex;
                justify-content: center;
                align-items: center;
                width: 100%;
                transition: 0.3s;
            }

                .btn-cancel:hover {
                    border-color: white;
                    color: white;
                    background: rgba(255,255,255,0.05);
                }
            
            /* Estilos para los textos de error */
            .text-danger {
                font-size: 0.85rem;
                font-weight: 500;
                margin-top: 5px;
                display: block;
                text-shadow: 0 0 5px rgba(220, 53, 69, 0.5);
            }
        
            .input-validation-error {
                border-color: #dc3545 !important;
                box-shadow: 0 0 10px rgba(220, 53, 69, 0.3) !important;
            }
    </style>
</head>
<body>

    <div class="tech-bg"></div>

    <nav class="navbar-main sticky-top shadow-sm z-3">
        <div class="container d-flex justify-content-between align-items-center">
            <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center text-decoration-none">
                <i class="bi bi-cpu-fill text-cyan-neon fs-3 me-2"></i>
                <span class="text-white fw-bold fs-5">ElectroMarket</span>
            </a>
        </div>
    </nav>

    <div class="container">
        <div class="form-card">
            <h2 class="fw-bold mb-4 text-center">Editar Producto</h2>

            @* 🚨 AQUÍ ESTÁ LA MAGIA: Agregamos "novalidate" para usar nuestro propio diseño de errores 🚨 *@
            <form asp-action="Edit" method="post" enctype="multipart/form-data" novalidate>
                
                <input type="hidden" asp-for="IdProducto" />
                <input type="hidden" asp-for="IdUsuario" />
                <input type="hidden" asp-for="FechaPublicacion" />
                <input type="hidden" asp-for="Vendido" />
                <input type="hidden" asp-for="ImagenUrl" />

                <div class="row g-4">
                    <div class="col-md-12">
                        <label asp-for="Nombre" class="form-label-tech">Nombre del Equipo</label>
                        <input asp-for="Nombre" class="form-control form-control-tech" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Precio" class="form-label-tech">PRECIO ($)</label>
                        <input asp-for="Precio" type="number" min="50000" max="20000000" step="0.01" class="form-control form-control-tech" placeholder="Ej: 1500000" required />
                        <span asp-validation-for="Precio" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Cantidad" class="form-label-tech">Stock (Cantidad)</label>
                        <input asp-for="Cantidad" type="number" class="form-control form-control-tech" />
                        <span asp-validation-for="Cantidad" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Categoria" class="form-label-tech">Categoría</label>
                        <input asp-for="Categoria" class="form-control form-control-tech" />
                        <span asp-validation-for="Categoria" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label-tech">Actualizar Imagen (Opcional)</label>
                        <div class="input-group">
                            <span class="input-group-text" style="background: rgba(0,0,0,0.5); border: 1px solid var(--border-color); color: var(--cyan-neon);">
                                <i class="bi bi-paperclip fs-5"></i>
                            </span>
                            <input type="file" name="imagenArchivo" class="form-control form-control-tech" accept="image/*" />
                        </div>

                        @if (!string.IsNullOrEmpty(Model?.ImagenUrl))
                        {
                            <small class="text-white-50 mt-2 d-block"><i class="bi bi-image me-1"></i> Imagen actual guardada: @Model.ImagenUrl</small>
                        }
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Descripcion" class="form-label-tech">Descripción Detallada</label>
                        <textarea asp-for="Descripcion" class="form-control form-control-tech" rows="4"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <div class="form-check p-3 border border-secondary rounded-3" style="background: rgba(255,193,7,0.1);">
                            <input class="form-check-input ms-1 me-2" type="checkbox" asp-for="RequiereReparacion" style="cursor:pointer;" id="repCheck">
                                <label class="form-check-label text-warning fw-bold" for="repCheck" style="cursor:pointer;">
                                    <i class="bi bi-tools me-1"></i> Este equipo requiere reparación o tiene detalles.
                                </label>
                            </div>
                        </div>

                        <div class="col-md-6 mt-5">
                            <button type="submit" class="btn-save"><i class="bi bi-save me-2"></i> Guardar Cambios</button>
                        </div>
                        <div class="col-md-6 mt-5">
                            <a asp-controller="Usuarios" asp-action="Perfil" class="btn-cancel">Cancelar</a>
                        </div>
                    </div>
                </form>

            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
        @* Este script agarra los errores y los pone en el texto rojo *@
        <partial name="_ValidationScriptsPartial" />
    </body>
</html>