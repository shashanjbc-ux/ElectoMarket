@model ElectoMarket.Models.Producto
@using Microsoft.AspNetCore.Http

@{
    Layout = null;
    var uId = Context.Session.GetInt32("UsuarioId");
    var uNombre = Context.Session.GetString("UsuarioNombre") ?? "Admin";
    var uFoto = Context.Session.GetString("UsuarioFoto");
    var miRol = Context.Session.GetInt32("UsuarioRol");
    bool esAdmin = miRol == 1;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Eliminar Producto - ElectroMarket</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --bg-dark: #08080a;
            --glass-bg: rgba(18, 18, 22, 0.85);
            --border-glass: rgba(255, 255, 255, 0.1);
            --morado: #7c4dff;
            --cyan-neon: #00d2ff;
            --danger-neon: #ff4d4d;
        }

        body {
            background-color: var(--bg-dark);
            color: white;
            font-family: 'Inter', system-ui, sans-serif;
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        /* --- FONDO TECH --- */
        .tech-bg {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1;
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(255, 77, 77, 0.08) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(124, 77, 255, 0.08) 0%, transparent 40%);
        }
        .tech-bg::after {
            content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0L30 60M0 30L60 30' stroke='rgba(255,255,255,0.02)' stroke-width='0.5'/%3E%3C/svg%3E");
        }

        /* --- NAVBAR PREMIUM --- */
        .navbar-custom {
            background: rgba(10, 10, 12, 0.9);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border-glass);
            padding: 12px 0;
            width: 100%;
        }

        .nav-link-tech {
            color: rgba(255,255,255,0.6);
            text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: 0.3s;
        }
        .nav-link-tech:hover { color: var(--cyan-neon); text-shadow: 0 0 10px var(--cyan-neon); }

        /* --- CONTENEDOR DE ELIMINACIÓN --- */
        .delete-container {
            flex-grow: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
        }

        .glass-warning-card {
            background: var(--glass-bg);
            backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 77, 77, 0.3);
            border-radius: 24px;
            width: 100%;
            max-width: 650px;
            overflow: hidden;
            box-shadow: 0 25px 50px rgba(0,0,0,0.6), 0 0 20px rgba(255, 77, 77, 0.1);
            animation: fadeIn 0.5s ease-out;
        }

        .warning-header {
            background: linear-gradient(90deg, rgba(255, 77, 77, 0.2), transparent);
            padding: 25px;
            border-bottom: 1px solid rgba(255, 77, 77, 0.2);
            text-align: center;
        }

        .warning-icon {
            font-size: 3rem;
            color: var(--danger-neon);
            filter: drop-shadow(0 0 10px var(--danger-neon));
            margin-bottom: 10px;
        }

        .product-preview-box {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-glass);
            border-radius: 18px;
            padding: 20px;
            margin: 30px;
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .preview-img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 12px;
            border: 1px solid var(--border-glass);
        }

        /* --- BOTONES --- */
        .btn-group-custom {
            padding: 0 30px 40px 30px;
            display: flex;
            gap: 15px;
        }

        .btn-delete-final {
            background: linear-gradient(135deg, #ff4d4d, #b30000);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 12px 25px;
            font-weight: 700;
            flex-grow: 2;
            transition: 0.3s;
            box-shadow: 0 10px 20px rgba(255, 77, 77, 0.3);
        }
        .btn-delete-final:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(255, 77, 255, 0.5);
            filter: brightness(1.2);
            color: white;
        }

        .btn-cancel-glass {
            background: rgba(255, 255, 255, 0.05);
            color: white;
            border: 1px solid var(--border-glass);
            border-radius: 12px;
            padding: 12px 25px;
            font-weight: 600;
            flex-grow: 1;
            transition: 0.3s;
            text-decoration: none;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .btn-cancel-glass:hover {
            background: white;
            color: black;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

    <div class="tech-bg"></div>

    @* NAVBAR UNIFICADA *@
    <nav class="navbar-custom">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center text-decoration-none">
                    <img src="/imagenes/Logo/Logo.jpg" alt="Logo" style="height: 40px; width: 40px; border-radius: 50%;">
                    <span class="text-white fw-bold fs-5 ms-2">ElectroMarket</span>
                </a>
                <div class="ms-5 d-flex gap-4">
                    <a asp-controller="Productos" asp-action="Index" class="nav-link-tech">Catálogo</a>
                    @if(esAdmin){
                        <a asp-controller="Productos" asp-action="Gestionar" class="nav-link-tech text-danger fw-bold"><i class="bi bi-shield-lock"></i> Panel Admin</a>
                    }
                </div>
            </div>

            <div class="d-flex align-items-center gap-3">
                <div class="d-flex align-items-center">
                    <img src="@(!string.IsNullOrEmpty(uFoto) ? uFoto : "/imagenes/placeholder-perfil.png")" 
                         class="rounded-circle border border-secondary me-2" style="width: 35px; height: 35px; object-fit: cover;">
                    <span class="small text-white-50">
                        Hola, <span class="text-white fw-bold">@uNombre</span>
                        @if(esAdmin){ <span class="text-warning small ms-1">(Admin)</span> }
                    </span>
                </div>
                <form asp-controller="Usuarios" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">Salir</button>
                </form>
            </div>
        </div>
    </nav>

    <div class="delete-container">
        <div class="glass-warning-card shadow-lg">
            
            <div class="warning-header">
                <div class="warning-icon">
                    <i class="bi bi-exclamation-octagon-fill"></i>
                </div>
                <h3 class="fw-bold m-0 text-white">¿Confirmar Eliminación?</h3>
                <p class="text-white-50 small mt-2">Esta acción es permanente y no se puede deshacer.</p>
            </div>

            <div class="product-preview-box">
                <img src="@(string.IsNullOrEmpty(Model.ImagenUrl) ? "/imagenes/no-image.png" : Model.ImagenUrl)" 
                     alt="@Model.Nombre" class="preview-img shadow">
                
                <div>
                    <h5 class="fw-bold m-0 text-white">@Model.Nombre</h5>
                    <div class="text-success fw-bold fs-5 mt-1">@Model.Precio.ToString("C0")</div>
                    <div class="text-white-50 small mt-2">
                        <i class="bi bi-person-circle me-1"></i> Vendedor: @(Model.Usuario?.Nombre ?? "Usuario")
                    </div>
                </div>
            </div>

            <div class="px-4 mb-4 text-center">
                <p class="small text-danger opacity-75">Se eliminarán todos los registros asociados a este equipo del sistema.</p>
            </div>

            <div class="btn-group-custom">
                @* Botón de Cancelar: Ahora te lleva al perfil si eres usuario *@
                <a asp-controller="Usuarios" asp-action="Perfil" class="btn-cancel-glass">
                    <i class="bi bi-x-lg me-2"></i>Cancelar
                </a>

                @* 🟢 FORMULARIO FUNCIONAL 🟢 *@
                <form asp-action="EliminarDefinitivamente" method="post" style="flex-grow: 2;">
                    @* VITAL: name="id" para que el controlador lo reciba *@
                    <input type="hidden" name="id" value="@Model.IdProducto" />
                    <button type="submit" class="btn-delete-final w-100">
                        <i class="bi bi-trash3-fill me-2"></i>Eliminar Definitivamente
                    </button>
                </form>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>