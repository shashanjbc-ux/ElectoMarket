@{
    Layout = null; // Diseño independiente
}
@using Microsoft.AspNetCore.Http

@{        
    // 🟢 Leemos la sesión para personalizar la bienvenida
    var uId = Context.Session.GetInt32("UsuarioId");
    var uNombre = Context.Session.GetString("UsuarioNombre") ?? "Invitado";
    var uFoto = Context.Session.GetString("UsuarioFoto");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inicio - ElectroMarket</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --bg-main: #0a0a0c;
            --bg-nav: #121214;
            --border-color: #27272a;
            --text-main: #ffffff;
            --text-muted: #a1a1aa;
            --morado: #7c4dff;
            --morado-hover: #651fff;
            --morado-glow: rgba(124, 77, 255, 0.4);
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            height: 100vh;
            display: flex;
            flex-direction: column;
            margin: 0;
            overflow: hidden;
        }
        
        /* --- NAVBAR SUPERIOR --- */
        .navbar-main {
            background-color: var(--bg-nav);
            border-bottom: 1px solid var(--border-color);
            padding: 12px 0;
        }
        
        .brand-logo-container {
            cursor: default;
            user-select: none;
        }
        
        .nav-link-custom {
            color: var(--text-muted);
            text-decoration: none;
            margin: 0 15px;
            transition: 0.2s;
            font-size: 0.95rem;
            font-weight: 500;
        }
        .nav-link-custom:hover { color: white; }
        
        .btn-salir {
            border: 1px solid #ef4444;
            color: #ef4444;
            border-radius: 20px;
            padding: 5px 20px;
            background: transparent;
            transition: 0.2s;
            font-size: 0.9rem;
            font-weight: 500;
        }
        .btn-salir:hover { background: #ef4444; color: white; }

        /* --- HERO SECTION --- */
        .hero-section { 
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center; 
            padding: 20px;
        }
        .hero-title { font-weight: 800; font-size: 4.5rem; letter-spacing: -2px; line-height: 1.1; }
        .hero-subtitle { color: var(--text-muted); font-size: 1.25rem; max-width: 650px; margin: 20px auto 45px auto; line-height: 1.6; }
        
        /* 🟢 Estilo mejorado para el botón de Conócenos */
        .btn-conocenos-hero {
            background-color: var(--morado); 
            color: white;
            border-radius: 50px; 
            padding: 18px 55px;
            font-weight: 700; 
            border: none; 
            font-size: 1.2rem;
            transition: 0.3s; 
            text-decoration: none;
            box-shadow: 0 10px 30px var(--morado-glow);
        }
        .btn-conocenos-hero:hover { 
            background-color: var(--morado-hover); 
            color: white; 
            transform: translateY(-3px);
            box-shadow: 0 15px 40px var(--morado-glow);
        }
    </style>
</head>
<body>

    @* NAVBAR SUPERIOR *@
    <nav class="navbar-main sticky-top">
        <div class="container d-flex justify-content-between align-items-center">
            
            <span class="brand-logo-container d-flex align-items-center m-0 p-0" title="ElectroMarket (Inicio)">
                <img src="/imagenes/Logo/Logo.jpg" alt="ElectroMarket" style="height: 50px; width: 50px; object-fit: contain; border-radius: 50%; box-shadow: 0 0 15px var(--morado-glow);">
                <span class="text-white fw-bold ms-2 fs-5 tracking-tight">ElectroMarket</span>
            </span>

            <div class="d-flex align-items-center">
                <div class="d-none d-md-flex me-4 border-end border-secondary pe-4">
                    <a asp-controller="Home" asp-action="Index" class="nav-link-custom text-white fw-bold">Inicio</a>
                    <a asp-controller="Productos" asp-action="Index" class="nav-link-custom">Tienda</a>
                </div>

                @if (uId != null)
                {
                    <a asp-controller="Usuarios" asp-action="Perfil" class="d-flex align-items-center text-decoration-none me-4">
                        <img src="@(!string.IsNullOrEmpty(uFoto) ? uFoto : "/imagenes/placeholder-perfil.png")" 
                             class="rounded-circle object-fit-cover me-2 border border-secondary" style="width: 35px; height: 35px;" />
                        <span class="text-white fw-bold" style="font-size: 0.95rem;">@uNombre</span>
                    </a>
                    
                    <form asp-controller="Usuarios" asp-action="Logout" method="post" class="m-0 p-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-salir">Salir</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Usuarios" asp-action="Login" class="nav-link-custom">Ingresar</a>
                    <a asp-controller="Usuarios" asp-action="Register" class="btn-salir" style="border-color: var(--morado); color: var(--morado);">Registrarse</a>
                }
            </div>
        </div>
    </nav>

    @* SECCIÓN CENTRAL DE BIENVENIDA *@
    <section class="hero-section container">
        <h1 class="hero-title text-white">Bienvenido a <br><span style="color: var(--morado);">ElectroMarket</span></h1>
        <p class="hero-subtitle">Descubre una nueva forma de comprar, vender y darle vida a la tecnología.</p>
        
        @* 🟢 BOTÓN CORREGIDO: Ahora apunta a Home/Conocenos *@
        <a asp-controller="Home" asp-action="Conocenos" class="btn-conocenos-hero">
            <i class="bi bi-info-circle me-2"></i> Conócenos
        </a>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>