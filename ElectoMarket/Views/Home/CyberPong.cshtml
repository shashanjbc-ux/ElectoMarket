@using Microsoft.AspNetCore.Http
@{ Layout = null; bool esInvitado = Context.Session.GetInt32("UsuarioId") == null; }
<!DOCTYPE html>
<html lang="es">
<head>
    <title>Cyber Pong</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #08080a; color: white; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        canvas { background: #050508; border: 2px solid #ff00ff; border-radius: 10px; box-shadow: 0 0 20px rgba(255, 0, 255, 0.2); }
        .score { font-size: 2rem; font-weight: 800; color: #ff00ff; text-shadow: 0 0 10px #ff00ff; margin-bottom: 10px; }
        a.btn-volver { color: #00d2ff; text-decoration: none; margin-top: 15px; font-weight: bold; border: 1px solid #00d2ff; padding: 5px 15px; border-radius: 5px; transition: 0.3s; }
        a.btn-volver:hover { background: #00d2ff; color: #000; box-shadow: 0 0 15px #00d2ff; }
    </style>
</head>
<body>
    <div class="score">TÚ: <span id="pScore">0</span> | IA: <span id="aiScore">0</span> (Nivel <span id="nivel">1</span>)</div>
    <canvas id="game" width="600" height="400"></canvas>
    <a href="/Home/Arcade" class="btn-volver">Volver al Arcade</a>

    <script>
        const cvs = document.getElementById('game'); const ctx = cvs.getContext('2d');
        const pScoreEl = document.getElementById('pScore'); const aiScoreEl = document.getElementById('aiScore'); const nivelEl = document.getElementById('nivel');
        const paddle = { w: 10, h: 80, speed: 6 }; const player = { x: 10, y: 160, score: 0 }; const ai = { x: 580, y: 160, score: 0, speed: 3 };
        const ball = { x: 300, y: 200, r: 8, speed: 4, dx: 4, dy: 4 };
        let level = 1; let gameOver = false; let upPressed = false, downPressed = false;

        document.addEventListener("keydown", e => { if(e.key==="ArrowUp" || e.key==="w") upPressed = true; if(e.key==="ArrowDown" || e.key==="s") downPressed = true; });
        document.addEventListener("keyup", e => { if(e.key==="ArrowUp" || e.key==="w") upPressed = false; if(e.key==="ArrowDown" || e.key==="s") downPressed = false; });
        function resetBall(winner) { ball.x = 300; ball.y = 200; ball.speed = 4 + (level * 0.5); ball.dx = (winner === "player" ? 1 : -1) * ball.speed; ball.dy = (Math.random() > 0.5 ? 1 : -1) * ball.speed; }
        function drawRect(x, y, w, h, color) { ctx.fillStyle = color; ctx.shadowBlur=10; ctx.shadowColor=color; ctx.fillRect(x, y, w, h); ctx.shadowBlur=0; }
        function drawCircle(x, y, r, color) { ctx.fillStyle = color; ctx.shadowBlur=15; ctx.shadowColor=color; ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI*2); ctx.fill(); ctx.shadowBlur=0; }
        function update() {
            if (gameOver) return;
            if (upPressed && player.y > 0) player.y -= paddle.speed;
            if (downPressed && player.y < cvs.height - paddle.h) player.y += paddle.speed;
            if (ai.y + paddle.h/2 < ball.y) ai.y += ai.speed;
            if (ai.y + paddle.h/2 > ball.y) ai.y -= ai.speed;
            ball.x += ball.dx; ball.y += ball.dy;
            if (ball.y - ball.r < 0 || ball.y + ball.r > cvs.height) ball.dy *= -1;
            let p = (ball.x < cvs.width/2) ? player : ai;
            if (ball.x + ball.r > p.x && ball.x - ball.r < p.x + paddle.w && ball.y + ball.r > p.y && ball.y - ball.r < p.y + paddle.h) { ball.dx *= -1; ball.dx += (ball.dx > 0 ? 0.2 : -0.2); }
            if (ball.x - ball.r < 0) { ai.score++; aiScoreEl.innerText = ai.score; resetBall("ai"); }
            else if (ball.x + ball.r > cvs.width) { player.score++; pScoreEl.innerText = player.score; if(player.score % 3 === 0) { level++; ai.speed += 0.8; nivelEl.innerText = level; } resetBall("player"); }
        }
        function draw() { ctx.clearRect(0,0, cvs.width, cvs.height); for(let i=0; i<cvs.height; i+=30) drawRect(298, i, 4, 15, "rgba(255,0,255,0.3)"); drawRect(player.x, player.y, paddle.w, paddle.h, "#00d2ff"); drawRect(ai.x, ai.y, paddle.w, paddle.h, "#ff2a55"); drawCircle(ball.x, ball.y, ball.r, "#ffffff"); }
        function loop() { update(); draw(); requestAnimationFrame(loop); } loop();
    </script>

    @if(esInvitado) {
        <div style="position: fixed; top: 20px; right: 20px; background: rgba(255, 74, 104, 0.1); border: 1px solid #ff4a68; color: #ff4a68; padding: 8px 15px; border-radius: 50px; font-weight: bold; font-family: monospace; z-index: 9999; box-shadow: 0 0 10px rgba(255,74,104,0.3); backdrop-filter: blur(5px);">
            ⏱️ Prueba: <span id="timeRemaining">15:00</span>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            let timeRemaining = localStorage.getItem('arcadeTimeLeft');
            if (timeRemaining === null) { timeRemaining = 15 * 60; } else { timeRemaining = parseInt(timeRemaining); }
            let timerInterval = setInterval(updateTimer, 1000); 
            function updateTimer() {
                if (timeRemaining <= 0) {
                    clearInterval(timerInterval); document.getElementById('timeRemaining').innerText = "00:00"; if (typeof gameOver !== 'undefined') gameOver = true; 
                    Swal.fire({ title: '<span style="color: #ff4a68; font-weight: 900; font-size: 2rem;">¡TIEMPO AGOTADO!</span>', html: '<span style="color: #ccc; font-size: 1.1rem;">Tu pase de prueba de 15 minutos ha terminado.<br><br><b style="color: white;">¡Regístrate GRATIS para jugar sin límites!</b><br><br><small style="color: #ff4a68;">Saliendo de la simulación en 30 segundos...</small></span>', icon: 'warning', background: '#161618', color: '#fff', allowOutsideClick: false, allowEscapeKey: false, showCancelButton: true, confirmButtonColor: '#7c4dff', cancelButtonColor: '#2d2d30', confirmButtonText: '¡Registrarme Ahora!', cancelButtonText: 'Volver a la Tienda', backdrop: `rgba(255, 74, 104, 0.2)`, timer: 30000, timerProgressBar: true }).then((result) => { if (result.isConfirmed) { window.location.href = '/Usuarios/Register'; } else { window.location.href = '/Home/Index'; } }); return;
                }
                let m = Math.floor(timeRemaining / 60); let s = timeRemaining % 60; document.getElementById('timeRemaining').innerText = (m < 10 ? "0" : "") + m + ":" + (s < 10 ? "0" : "") + s;
                timeRemaining--; localStorage.setItem('arcadeTimeLeft', timeRemaining);
            } updateTimer();
        </script>
    } else {
        <div style="position: fixed; top: 20px; right: 20px; background: rgba(0, 255, 136, 0.1); border: 1px solid #00ff88; color: #00ff88; padding: 8px 15px; border-radius: 50px; font-weight: bold; font-family: monospace; z-index: 9999; box-shadow: 0 0 10px rgba(0,255,136,0.3); backdrop-filter: blur(5px);">👑 PASE VIP: Ilimitado</div>
    }
</body></html>