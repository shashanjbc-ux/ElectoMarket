@using Microsoft.AspNetCore.Http
@{
    Layout = null;
    bool esInvitado = Context.Session.GetInt32("UsuarioId") == null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Arcade - ElectroMarket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root { --bg-dark: #08080a; --morado: #7c4dff; --cyan-neon: #00d2ff; --rojo-laser: #ff2a55; --verde-neon: #00ff88; }
        body { background-color: var(--bg-dark); color: white; font-family: 'Inter', system-ui, sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; margin: 0; overflow: hidden; }
        .tech-bg { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; background-image: radial-gradient(circle at 50% 50%, rgba(124, 77, 255, 0.1) 0%, transparent 60%); }
        .game-container { background: rgba(18, 18, 22, 0.85); backdrop-filter: blur(15px); border: 2px solid var(--morado); border-radius: 20px; padding: 30px; box-shadow: 0 0 30px rgba(124, 77, 255, 0.3); text-align: center; position: relative; }
        canvas { background-color: #050508; border: 2px solid rgba(0, 210, 255, 0.3); border-radius: 10px; box-shadow: 0 0 20px rgba(0, 210, 255, 0.1); margin-top: 15px; }
        .stats-panel { display: flex; justify-content: center; gap: 30px; margin-bottom: 10px; }
        .score-board { font-size: 1.3rem; font-weight: 800; color: var(--cyan-neon); text-shadow: 0 0 10px rgba(0, 210, 255, 0.5); }
        .level-board { font-size: 1.3rem; font-weight: 800; color: var(--verde-neon); text-shadow: 0 0 10px rgba(0, 255, 136, 0.5); }
        .btn-tech { background: transparent; color: var(--cyan-neon); border: 1px solid var(--cyan-neon); padding: 8px 20px; border-radius: 8px; font-weight: bold; transition: 0.3s; text-decoration: none; margin-top: 20px; display: inline-block; }
        .btn-tech:hover { background: var(--cyan-neon); color: black; box-shadow: 0 0 15px rgba(0, 210, 255, 0.4); }
        #levelUpMsg { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 2rem; font-weight: 900; color: var(--verde-neon); text-shadow: 0 0 20px var(--verde-neon); pointer-events: none; opacity: 0; transition: opacity 0.5s; }
    </style>
</head>
<body>
    <div class="tech-bg"></div>
    <div class="game-container">
        <h2 class="fw-bold mb-1"><i class="bi bi-controller me-2" style="color: var(--morado);"></i>Electro Snake <span style="font-size:0.8rem; color:var(--rojo-laser);">EXTREME</span></h2>
        <p class="text-white-50 small mb-3">Las flechas mueven. Cuidado con los muros rojos.</p>
        <div class="stats-panel">
            <div class="score-board">PTS: <span id="score">0</span></div>
            <div class="level-board">NIVEL: <span id="level">1</span></div>
        </div>
        <div style="position: relative;">
            <canvas id="gameCanvas" width="400" height="400"></canvas>
            <div id="levelUpMsg">¡NIVEL SUPERADO!</div>
        </div>
        <div id="gameOverMsg" class="text-danger fw-bold mt-3 d-none" style="font-size: 1.2rem; text-shadow: 0 0 10px red;">
            ¡SISTEMA CAÍDO! Presiona ESPACIO para reiniciar.
        </div>
        <div><a asp-controller="Home" asp-action="Arcade" class="btn-tech mt-4"><i class="bi bi-arrow-left me-1"></i> Volver al Arcade</a></div>
    </div>

    <script>
        const canvas = document.getElementById("gameCanvas"); const ctx = canvas.getContext("2d");
        const scoreElement = document.getElementById("score"); const levelElement = document.getElementById("level");
        const gameOverMsg = document.getElementById("gameOverMsg"); const levelUpMsg = document.getElementById("levelUpMsg");
        const gridSize = 20; let snake = []; let food = {}; let obstacles = []; let dx = 0; let dy = 0;
        let score = 0; let level = 1; let gameSpeed = 120; let gameOver = false; let gameLoop;
        const snakeColor = "#00d2ff"; const foodColor = "#7c4dff"; const obsColor = "#ff2a55";

        function randomPosition() { return Math.floor(Math.random() * (canvas.width / gridSize)) * gridSize; }
        function checkCollision(x, y, array) { for (let i = 0; i < array.length; i++) { if (array[i].x === x && array[i].y === y) return true; } return false; }
        function generateFood() { let newFood; while (true) { newFood = { x: randomPosition(), y: randomPosition() }; if (!checkCollision(newFood.x, newFood.y, snake) && !checkCollision(newFood.x, newFood.y, obstacles)) break; } return newFood; }
        function generateObstacles() { obstacles = []; let numObstacles = (level - 1) * 4; for (let i = 0; i < numObstacles; i++) { let obs; while(true) { obs = { x: randomPosition(), y: randomPosition() }; let inSafeZone = (obs.x >= 140 && obs.x <= 260 && obs.y >= 140 && obs.y <= 260); if (!checkCollision(obs.x, obs.y, snake) && !(obs.x === food.x && obs.y === food.y) && !inSafeZone) break; } obstacles.push(obs); } }
        function triggerLevelUp() { level++; levelElement.innerText = level; gameSpeed = Math.max(45, gameSpeed - 15); generateObstacles(); levelUpMsg.style.opacity = 1; setTimeout(() => { levelUpMsg.style.opacity = 0; }, 1000); clearInterval(gameLoop); gameLoop = setInterval(main, gameSpeed); }
        function drawRect(x, y, color, isGlow, blurAmount = 10) { ctx.fillStyle = color; if (isGlow) { ctx.shadowBlur = blurAmount; ctx.shadowColor = color; } else { ctx.shadowBlur = 0; } ctx.fillRect(x, y, gridSize - 2, gridSize - 2); ctx.shadowBlur = 0; }
        function update() {
            if (gameOver) return;
            const head = { x: snake[0].x + dx, y: snake[0].y + dy };
            if (head.x < 0) head.x = canvas.width - gridSize; if (head.x >= canvas.width) head.x = 0;
            if (head.y < 0) head.y = canvas.height - gridSize; if (head.y >= canvas.height) head.y = 0;
            if (checkCollision(head.x, head.y, snake) || checkCollision(head.x, head.y, obstacles)) { endGame(); return; }
            snake.unshift(head);
            if (head.x === food.x && head.y === food.y) { score += 10; scoreElement.innerText = score; if (score % 50 === 0) triggerLevelUp(); food = generateFood(); } else { snake.pop(); }
        }
        function draw() { ctx.clearRect(0, 0, canvas.width, canvas.height); obstacles.forEach(obs => drawRect(obs.x, obs.y, obsColor, true, 15)); drawRect(food.x, food.y, foodColor, true); snake.forEach((part, index) => { drawRect(part.x, part.y, snakeColor, index === 0); }); }
        function main() { update(); draw(); }
        function endGame() { gameOver = true; gameOverMsg.classList.remove("d-none"); clearInterval(gameLoop); }
        function resetGame() { snake = [{ x: 200, y: 200 }]; dx = gridSize; dy = 0; score = 0; level = 1; gameSpeed = 120; obstacles = []; scoreElement.innerText = score; levelElement.innerText = level; food = generateFood(); gameOver = false; gameOverMsg.classList.add("d-none"); clearInterval(gameLoop); gameLoop = setInterval(main, gameSpeed); }
        window.addEventListener("keydown", e => { if (e.key === "ArrowUp" && dy === 0) { dx = 0; dy = -gridSize; } else if (e.key === "ArrowDown" && dy === 0) { dx = 0; dy = gridSize; } else if (e.key === "ArrowLeft" && dx === 0) { dx = -gridSize; dy = 0; } else if (e.key === "ArrowRight" && dx === 0) { dx = gridSize; dy = 0; } if (e.key === " " && gameOver) resetGame(); if(["Space","ArrowUp","ArrowDown","ArrowLeft","ArrowRight"].indexOf(e.code) > -1) e.preventDefault(); });
        resetGame();
    </script>

    @if(esInvitado) {
        <div style="position: fixed; top: 20px; right: 20px; background: rgba(255, 74, 104, 0.1); border: 1px solid #ff4a68; color: #ff4a68; padding: 8px 15px; border-radius: 50px; font-weight: bold; font-family: monospace; z-index: 9999; box-shadow: 0 0 10px rgba(255,74,104,0.3); backdrop-filter: blur(5px);">
            ⏱️ Prueba: <span id="timeRemaining">15:00</span>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            let timeRemaining = localStorage.getItem('arcadeTimeLeft');
            if (timeRemaining === null) { timeRemaining = 15 * 60; } else { timeRemaining = parseInt(timeRemaining); }
            let timerInterval = setInterval(updateTimer, 1000); 

            function updateTimer() {
                if (timeRemaining <= 0) {
                    clearInterval(timerInterval);
                    document.getElementById('timeRemaining').innerText = "00:00";
                    if (typeof gameOver !== 'undefined') gameOver = true; 
                    
                    Swal.fire({
                        title: '<span style="color: #ff4a68; font-weight: 900; font-size: 2rem;">¡TIEMPO AGOTADO!</span>',
                        html: '<span style="color: #ccc; font-size: 1.1rem;">Tu pase de prueba de 15 minutos ha terminado.<br><br><b style="color: white;">¡Regístrate GRATIS para jugar sin límites!</b><br><br><small style="color: #ff4a68;">Saliendo de la simulación en 30 segundos...</small></span>',
                        icon: 'warning', background: '#161618', color: '#fff',
                        allowOutsideClick: false, allowEscapeKey: false, showCancelButton: true,
                        confirmButtonColor: '#7c4dff', cancelButtonColor: '#2d2d30',
                        confirmButtonText: '¡Registrarme Ahora!', cancelButtonText: 'Volver a la Tienda',
                        backdrop: `rgba(255, 74, 104, 0.2)`, timer: 30000, timerProgressBar: true
                    }).then((result) => {
                        if (result.isConfirmed) { window.location.href = '/Usuarios/Register'; } 
                        else { window.location.href = '/Home/Index'; }
                    });
                    return;
                }
                let m = Math.floor(timeRemaining / 60); let s = timeRemaining % 60;
                document.getElementById('timeRemaining').innerText = (m < 10 ? "0" : "") + m + ":" + (s < 10 ? "0" : "") + s;
                timeRemaining--; localStorage.setItem('arcadeTimeLeft', timeRemaining);
            }
            updateTimer();
        </script>
    } else {
        <div style="position: fixed; top: 20px; right: 20px; background: rgba(0, 255, 136, 0.1); border: 1px solid #00ff88; color: #00ff88; padding: 8px 15px; border-radius: 50px; font-weight: bold; font-family: monospace; z-index: 9999; box-shadow: 0 0 10px rgba(0,255,136,0.3); backdrop-filter: blur(5px);">
            👑 PASE VIP: Ilimitado
        </div>
    }
</body>
</html>