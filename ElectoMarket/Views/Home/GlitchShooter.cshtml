@using Microsoft.AspNetCore.Http
@{ Layout = null; bool esInvitado = Context.Session.GetInt32("UsuarioId") == null; }
<!DOCTYPE html>
<html lang="es">
<head>
    <title>Glitch Shooter</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #08080a; color: white; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        canvas { background: #050508; border: 2px solid #ff2a55; border-radius: 10px; box-shadow: 0 0 20px rgba(255, 42, 85, 0.2); }
        .score { font-size: 2rem; font-weight: 800; color: #ff2a55; margin-bottom: 10px; }
        a.btn-volver { color: #00ff88; text-decoration: none; margin-top: 15px; font-weight: bold; border: 1px solid #00ff88; padding: 5px 15px; border-radius: 5px; transition: 0.3s; }
        a.btn-volver:hover { background: #00ff88; color: #000; box-shadow: 0 0 15px #00ff88; }
    </style>
</head>
<body>
    <div class="score">VIRUS ELIMINADOS: <span id="score">0</span></div>
    <canvas id="game" width="400" height="500"></canvas>
    <p class="text-white-50 mt-2">Flechas I/D para mover. ESPACIO para disparar.</p>
    <a href="/Home/Arcade" class="btn-volver">Volver al Arcade</a>

    <script>
        const cvs = document.getElementById('game'); const ctx = cvs.getContext('2d'); const scoreEl = document.getElementById('score');
        let player = { x: 180, y: 450, w: 40, h: 20, speed: 5 }; let bullets = []; let enemies = []; let score = 0, level = 1; let left = false, right = false; let gameOver = false;

        document.addEventListener("keydown", e => { if (e.key==="ArrowLeft") left = true; if (e.key==="ArrowRight") right = true; if (e.code==="Space" && !gameOver) bullets.push({ x: player.x + 18, y: player.y, w: 4, h: 10 }); if (e.code==="Space" && gameOver) reset(); if(["Space","ArrowUp","ArrowDown","ArrowLeft","ArrowRight"].indexOf(e.code) > -1) { e.preventDefault(); } });
        document.addEventListener("keyup", e => { if (e.key==="ArrowLeft") left = false; if (e.key==="ArrowRight") right = false; });
        function spawnEnemies() { enemies = []; for(let r=0; r<3; r++) { for(let c=0; c<6; c++) { enemies.push({ x: 30 + c*60, y: 30 + r*40, w: 30, h: 20 }); } } }
        function reset() { score=0; level=1; bullets=[]; player.x=180; gameOver=false; scoreEl.innerText=0; spawnEnemies(); loop(); }
        function update() {
            if(gameOver) return;
            if(left && player.x > 0) player.x -= player.speed; if(right && player.x < cvs.width - player.w) player.x += player.speed;
            bullets.forEach(b => b.y -= 7); bullets = bullets.filter(b => b.y > 0);
            let speedDrop = 0.5 + (level * 0.2); enemies.forEach(e => { e.y += speedDrop; if(e.y + e.h > player.y) gameOver = true; });
            bullets.forEach((b, bIdx) => { enemies.forEach((e, eIdx) => { if(b.x < e.x+e.w && b.x+b.w > e.x && b.y < e.y+e.h && b.y+b.h > e.y) { enemies.splice(eIdx, 1); bullets.splice(bIdx, 1); score++; scoreEl.innerText = score; } }); });
            if(enemies.length === 0) { level++; spawnEnemies(); }
        }
        function drawRect(x, y, w, h, color, blur=15) { ctx.fillStyle = color; ctx.shadowBlur=blur; ctx.shadowColor=color; ctx.fillRect(x, y, w, h); ctx.shadowBlur=0; }
        function draw() {
            ctx.clearRect(0,0, cvs.width, cvs.height); drawRect(player.x, player.y, player.w, player.h, "#00d2ff"); bullets.forEach(b => drawRect(b.x, b.y, b.w, b.h, "#00ff88", 5)); enemies.forEach(e => drawRect(e.x, e.y, e.w, e.h, "#ff2a55")); 
            if(gameOver) { ctx.fillStyle="white"; ctx.font="25px Arial"; ctx.fillText("INVASIÓN! Presiona Espacio", 40, 250); }
        }
        function loop() { update(); draw(); if(!gameOver) requestAnimationFrame(loop); } spawnEnemies(); loop();
    </script>

    @if(esInvitado) {
        <div style="position: fixed; top: 20px; right: 20px; background: rgba(255, 74, 104, 0.1); border: 1px solid #ff4a68; color: #ff4a68; padding: 8px 15px; border-radius: 50px; font-weight: bold; font-family: monospace; z-index: 9999; box-shadow: 0 0 10px rgba(255,74,104,0.3); backdrop-filter: blur(5px);">⏱️ Prueba: <span id="timeRemaining">15:00</span></div>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            let timeRemaining = localStorage.getItem('arcadeTimeLeft');
            if (timeRemaining === null) { timeRemaining = 15 * 60; } else { timeRemaining = parseInt(timeRemaining); }
            let timerInterval = setInterval(updateTimer, 1000); 
            function updateTimer() {
                if (timeRemaining <= 0) {
                    clearInterval(timerInterval); document.getElementById('timeRemaining').innerText = "00:00"; if (typeof gameOver !== 'undefined') gameOver = true; 
                    Swal.fire({ title: '<span style="color: #ff4a68; font-weight: 900; font-size: 2rem;">¡TIEMPO AGOTADO!</span>', html: '<span style="color: #ccc; font-size: 1.1rem;">Tu pase de prueba de 15 minutos ha terminado.<br><br><b style="color: white;">¡Regístrate GRATIS para jugar sin límites!</b><br><br><small style="color: #ff4a68;">Saliendo de la simulación en 30 segundos...</small></span>', icon: 'warning', background: '#161618', color: '#fff', allowOutsideClick: false, allowEscapeKey: false, showCancelButton: true, confirmButtonColor: '#7c4dff', cancelButtonColor: '#2d2d30', confirmButtonText: '¡Registrarme Ahora!', cancelButtonText: 'Volver a la Tienda', backdrop: `rgba(255, 74, 104, 0.2)`, timer: 30000, timerProgressBar: true }).then((result) => { if (result.isConfirmed) { window.location.href = '/Usuarios/Register'; } else { window.location.href = '/Home/Index'; } }); return;
                }
                let m = Math.floor(timeRemaining / 60); let s = timeRemaining % 60; document.getElementById('timeRemaining').innerText = (m < 10 ? "0" : "") + m + ":" + (s < 10 ? "0" : "") + s; timeRemaining--; localStorage.setItem('arcadeTimeLeft', timeRemaining);
            } updateTimer();
        </script>
    } else { <div style="position: fixed; top: 20px; right: 20px; background: rgba(0, 255, 136, 0.1); border: 1px solid #00ff88; color: #00ff88; padding: 8px 15px; border-radius: 50px; font-weight: bold; font-family: monospace; z-index: 9999; box-shadow: 0 0 10px rgba(0,255,136,0.3); backdrop-filter: blur(5px);">👑 PASE VIP: Ilimitado</div> }
</body></html>