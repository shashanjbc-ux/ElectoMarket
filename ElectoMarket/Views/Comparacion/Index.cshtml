@model ElectoMarket.Models.ComparacionViewModel
@using Microsoft.AspNetCore.Http
@using ElectoMarket.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext _context

@{
    Layout = null;
    var uId = Context.Session.GetInt32("UsuarioId");
    var uNombre = Context.Session.GetString("UsuarioNombre") ?? "Invitado";
    var uFoto = Context.Session.GetString("UsuarioFoto");
    var miRol = Context.Session.GetInt32("UsuarioRol");
    bool esAdmin = miRol == 1;

    // 🔴 CONTADOR DE MENSAJES NO LEÍDOS
    int mensajesSinLeer = 0;
    if (uId != null)
    {
        mensajesSinLeer = _context.Mensajes
            .Include(m => m.Chat)
            .Count(m => !m.Leido && m.RemitenteId != uId && (m.Chat.Usuario1Id == uId || m.Chat.Usuario2Id == uId));
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Comparacion De Productos - ElectroMarket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --bg-dark: #08080a;
            --glass-card: rgba(255, 255, 255, 0.03);
            --border-tech: rgba(255, 255, 255, 0.1);
            --cyan-neon: #00d2ff;
            --morado-neon: #7c4dff;
        }

        body { background-color: var(--bg-dark); color: white; font-family: 'Inter', sans-serif; overflow-x: hidden; }

        /* --- NAVBAR PREMIUM --- */
        .navbar-custom {
            background: rgba(10, 10, 12, 0.9);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border-tech);
            padding: 12px 0;
        }

        .hover-zoom { transition: 0.2s; display: inline-block; }
        .hover-zoom:hover { transform: scale(1.1); }

        /* 🟢 NUEVOS ESTILOS PERFIL INTERACTIVO 🟢 */
        .profile-link {
            padding: 5px 10px;
            border-radius: 12px;
            transition: 0.3s;
        }

        .profile-link:hover {
            background: rgba(255, 255, 255, 0.05);
            transform: translateY(-2px);
        }

        .profile-link:hover img {
            border-color: var(--cyan-neon) !important;
            box-shadow: 0 0 10px var(--cyan-neon);
        }

        /* --- CONTENEDOR DE TARJETAS --- */
        .comparison-wrapper {
            display: flex;
            gap: 20px;
            overflow-x: auto;
            padding: 20px 0;
            justify-content: center;
        }

        .compare-card {
            background: #fff;
            color: #333;
            border-radius: 12px;
            width: 320px;
            min-width: 320px;
            display: flex;
            flex-direction: column;
            position: relative;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border: 4px solid transparent;
            transition: 0.3s;
        }
        .compare-card:hover { border-color: var(--cyan-neon); transform: translateY(-5px); }

        .card-header-tech {
            background: #2d2d30;
            color: white;
            padding: 15px;
            text-align: center;
            font-weight: 800;
            border-radius: 8px 8px 0 0;
            text-transform: uppercase;
        }

        .img-box { padding: 15px; position: relative; text-align: center; }
        .img-compare { width: 100%; height: 200px; object-fit: cover; border-radius: 8px; }

        .price-badge {
            position: absolute; top: 25px; right: 25px;
            background: #000; color: white;
            padding: 5px 12px; border-radius: 20px; font-weight: 700;
        }

        .spec-list { padding: 20px; flex-grow: 1; }
        .spec-item { 
            border-bottom: 1px solid #eee; 
            padding: 8px 0; 
            font-size: 0.85rem;
            display: flex;
            justify-content: space-between;
        }
        .spec-label { font-weight: 700; color: #777; }

        .btn-remove {
            position: absolute; top: -10px; right: -10px;
            background: #ff4d4d; color: white; width: 30px; height: 30px;
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            text-decoration: none; border: 2px solid white;
            z-index: 10;
        }

        .empty-box {
            border: 2px dashed var(--border-tech);
            border-radius: 24px;
            padding: 80px 20px;
            text-align: center;
            margin-top: 50px;
        }
    </style>
</head>
<body>

    @* NAVBAR ACTUALIZADA CON GLOBO DE NOTIFICACIÓN *@
    <nav class="navbar-custom">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none d-flex align-items-center">
                    <img src="/imagenes/Logo/Logo.jpg" style="height: 40px; border-radius: 50%;">
                    <span class="text-white fw-bold ms-2">ElectroMarket</span>
                </a>
                <div class="ms-4 d-flex gap-3 align-items-center">
                    <a asp-controller="Productos" asp-action="Index" class="text-white-50 small text-decoration-none fw-bold"><i class="bi bi-shop me-1"></i>Catálogo</a>
                    <a href="#" class="text-white small fw-bold text-decoration-none"><i class="bi bi-arrow-left-right me-1"></i>Versus Tech</a>
                    <a asp-controller="Guias" asp-action="Index" class="text-white-50 small text-decoration-none fw-bold" style="color: #00ff88 !important; opacity: 0.8; transition: 0.3s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.8'">
                        <i class="bi bi-play-btn-fill" style="text-shadow: 0 0 8px rgba(0,255,136,0.5);"></i> Tutoriales
                    </a>
                </div>
            </div>

            @* 🟢 PERFIL INTERACTIVO Y LOGIN CONDICIONAL 🟢 *@
            <div class="d-flex align-items-center gap-3">
                @if (uId != null)
                {
                    <a asp-controller="Chats" asp-action="Index" class="text-white text-decoration-none position-relative hover-zoom me-2" title="Mis Mensajes">
                        <i class="bi bi-chat-dots fs-5"></i>
                        @if (mensajesSinLeer > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow-sm" 
                                  style="font-size: 0.65rem; padding: 0.35em 0.65em; transform: translate(-30%, -10%) !important;">
                                @(mensajesSinLeer > 99 ? "99+" : mensajesSinLeer.ToString())
                            </span>
                        }
                    </a>

                    <a asp-controller="Usuarios" asp-action="Perfil" class="d-flex align-items-center text-decoration-none profile-link">
                        <img src="@(!string.IsNullOrEmpty(uFoto) ? uFoto : "/imagenes/placeholder-perfil.png")" 
                             class="rounded-circle border border-secondary me-2" 
                             style="width: 38px; height: 38px; object-fit: cover; transition: 0.3s;">
                        
                        <div class="text-start">
                            <div class="small text-white-50 lh-1">Hola,</div>
                            <div class="text-white fw-bold lh-1">@uNombre</div>
                            
                            @if(esAdmin){
                                <span class="badge bg-warning text-dark fw-bold mt-1" style="font-size: 0.6rem; padding: 2px 6px;">
                                    <i class="bi bi-shield-fill"></i> ADMIN
                                </span>
                            }
                        </div>
                    </a>

                    <form asp-controller="Usuarios" asp-action="Logout" method="post" class="m-0 ms-2">
                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3" style="font-size: 0.8rem;">Salir</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Usuarios" asp-action="Login" class="text-white text-decoration-none fw-bold transition-all" style="opacity: 0.8;">
                        Iniciar Sesión
                    </a>
                    <a asp-controller="Usuarios" asp-action="Register" class="btn btn-sm rounded-pill px-4 fw-bold" style="background-color: transparent; border: 1px solid var(--morado-neon); color: var(--morado-neon); transition: 0.3s;">
                        Registrarse
                    </a>
                }
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h1 class="fw-black m-0"><i class="bi bi-arrow-left-right text-cyan-neon me-2"></i>Versus <span class="text-cyan-neon">Tech</span></h1>
                <p class="text-white-50">Compara especificaciones técnicas y precios de tus equipos favoritos.</p>
            </div>
            @if (Model.Productos.Any()) {
                <a asp-action="LimpiarTodo" class="btn btn-outline-danger btn-sm rounded-pill">
                    <i class="bi bi-trash3 me-1"></i> Limpiar Comparación
                </a>
            }
        </div>

        @if (!Model.Productos.Any())
        {
            <div class="empty-box">
                <i class="bi bi-layout-three-columns display-1 text-white-50 opacity-25 mb-4"></i>
                <h3>Tu panel de comparación está vacío</h3>
                <p class="text-white-50">Añade productos desde el catálogo para verlos aquí.</p>
                <a asp-controller="Productos" asp-action="Index" class="btn btn-primary rounded-pill px-4 mt-3">Explorar Catálogo</a>
            </div>
        }
        else
        {
            <div class="comparison-wrapper">
                @foreach (var (item, index) in Model.Productos.Select((value, i) => (value, i)))
                {
                    <div class="compare-card">
                        <a asp-action="Quitar" asp-route-id="@item.IdProducto" class="btn-remove" title="Quitar">
                            <i class="bi bi-x-lg"></i>
                        </a>
                        
                        <div class="card-header-tech">Opción @(index + 1)</div>
                        
                        <div class="img-box">
                            <span class="price-badge">@item.Precio.ToString("C0")</span>
                            <img src="@(string.IsNullOrEmpty(item.ImagenUrl) ? "/imagenes/no-image.png" : item.ImagenUrl)" class="img-compare shadow">
                            @if(item.RequiereReparacion){
                                <span class="badge bg-warning text-dark position-absolute bottom-0 start-50 translate-middle-x mb-4 fw-bold">USADO / REPARAR</span>
                            } else {
                                <span class="badge bg-success position-absolute bottom-0 start-50 translate-middle-x mb-4 fw-bold">DISPONIBLE</span>
                            }
                        </div>

                        <div class="spec-list">
                            <h6 class="fw-bold text-uppercase mb-3">@item.Nombre</h6>
                            
                            <div class="spec-item"><span class="spec-label">Categoría:</span> <span>@item.Categoria</span></div>
                            <div class="spec-item"><span class="spec-label">Vendedor:</span> <span>@(item.Usuario?.Nombre ?? "Externo")</span></div>
                            <div class="spec-item"><span class="spec-label">Stock:</span> <span>@item.Cantidad unidades</span></div>
                            <div class="spec-item"><span class="spec-label">Publicado:</span> <span>@item.FechaPublicacion.ToString("dd/MM/yyyy")</span></div>
                            
                            <div class="mt-3">
                                <span class="spec-label d-block mb-1">Descripción:</span>
                                <p class="small text-muted" style="height: 60px; overflow-y: auto;">@item.Descripcion</p>
                            </div>

                            <a asp-controller="Productos" asp-action="Details" asp-route-id="@item.IdProducto" 
                               class="btn btn-dark w-100 mt-3 fw-bold rounded-pill">VER DETALLES</a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>