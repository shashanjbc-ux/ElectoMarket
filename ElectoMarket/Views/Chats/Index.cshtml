@model ElectoMarket.Models.Chat
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    Layout = null; // 🟢 FUNDAMENTAL: Desconecta el layout blanco por defecto

    ViewData["Title"] = "Mis Chats";
    var misChats = ViewBag.MisChats as List<ElectoMarket.Models.Chat>;
    int miId = ViewBag.MiId ?? 0;
    int? miRol = HttpContextAccessor.HttpContext?.Session.GetInt32("UsuarioRol");
    bool esAdmin = miRol == 1;

    // Variables para la Navbar
    var uNombre = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioNombre") ?? "Usuario";
    var uFoto = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioFoto");

    // Lógica para saber mi color actual
    string miColorSignalR = "bg-primary text-white"; // Color por defecto para JS
    if (Model != null)
    {
        bool soyYo = Model.Usuario1Id == miId;
        miColorSignalR = soyYo ? Model.ColorBurbujaUsuario1 : Model.ColorBurbujaUsuario2;
        miColorSignalR = miColorSignalR ?? "bg-morado text-white";
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mis Chats - ElectroMarket</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --bg-dark: #08080a;
            --glass-bg: rgba(18, 18, 22, 0.85);
            --border-glass: rgba(255, 255, 255, 0.1);
            --morado-neon: #7c4dff;
            --cyan-neon: #00d2ff;
            --verde-neon: #00ff88;
        }

        body {
            background-color: var(--bg-dark);
            color: white;
            font-family: 'Inter', system-ui, sans-serif;
            height: 100vh;
            margin: 0;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .tech-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background-image: radial-gradient(circle at 10% 20%, rgba(124, 77, 255, 0.12) 0%, transparent 40%), radial-gradient(circle at 90% 80%, rgba(0, 210, 255, 0.1) 0%, transparent 40%);
        }

        /* --- NAVBAR ESTILO PREMIUM --- */
        .navbar-custom {
            background: rgba(10, 10, 12, 0.9);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border-glass);
            padding: 12px 0;
            flex-shrink: 0;
        }

        .nav-link-tech {
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            transition: 0.3s;
            display: flex;
            align-items: center;
        }

            .nav-link-tech:hover {
                color: var(--cyan-neon);
                text-shadow: 0 0 10px var(--cyan-neon);
            }

        .chat-icon-btn {
            position: relative;
            color: white;
            font-size: 1.2rem;
            transition: 0.3s;
        }

        .chat-badge {
            position: absolute;
            top: -2px;
            right: -2px;
            width: 8px;
            height: 8px;
            background: var(--verde-neon);
            border-radius: 50%;
            box-shadow: 0 0 10px var(--verde-neon);
        }

        .hover-white:hover {
            color: white !important;
            transition: 0.2s;
        }

        /* --- ESTILOS DEL CHAT --- */
        .chat-fullscreen {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            width: 100%;
        }

        .bg-morado {
            background-color: #6f2dbd !important;
        }

        .contact-box {
            transition: 0.2s;
            opacity: 0.8;
        }

        .active-chat-box {
            border-left: 5px solid var(--cyan-neon) !important;
            background-color: #1a1a1a !important;
            opacity: 1;
        }

        .card-hover:hover {
            transform: scale(1.05);
            transition: 0.2s;
        }

        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.2);
            border-radius: 10px;
        }

        .form-control:focus {
            box-shadow: none;
            border-color: var(--morado-neon);
        }
    </style>
</head>
<body>

    <div class="tech-bg"></div>

    @* NAVBAR PREMIUM *@
    <nav class="navbar-custom z-3">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center text-decoration-none">
                    <img src="/imagenes/Logo/Logo.jpg" alt="Logo" style="height: 40px; width: 40px; border-radius: 50%; background-color: white;">
                    <span class="text-white fw-bold fs-5 ms-2">ElectroMarket</span>
                </a>

                <div class="ms-5 d-flex gap-4">
                    <a asp-controller="Productos" asp-action="Index" class="nav-link-tech"><i class="bi bi-shop me-1"></i> Catálogo</a>
                    @if (esAdmin)
                    {
                        <a asp-controller="Home" asp-action="Index" class="nav-link-tech"><i class="bi bi-shield-lock me-1"></i> Inicio</a>
                        <a asp-controller="Usuarios" asp-action="ListadoUsuarios" class="nav-link-tech"><i class="bi bi-people me-1"></i> Gestión Usuarios</a>
                        <a asp-controller="Productos" asp-action="Gestionar" class="nav-link-tech"><i class="bi bi-box-seam me-1"></i> Gestión Productos</a>
                    }
                </div>
            </div>

            <div class="d-flex align-items-center gap-4">
                <a asp-controller="Chats" asp-action="Index" class="chat-icon-btn" title="Mensajes">
                    <i class="bi bi-chat-dots"></i><span class="chat-badge"></span>
                </a>

                <a asp-controller="Usuarios" asp-action="Perfil" class="d-flex align-items-center text-decoration-none">
                    <img src="@(!string.IsNullOrEmpty(uFoto) ? uFoto : "/imagenes/placeholder-perfil.png")" class="rounded-circle border border-secondary me-2" style="width: 35px; height: 35px; object-fit: cover;">
                    <span class="text-white-50 small hover-white">
                        Hola, <span class="fw-bold text-white">@uNombre</span>
                        @if (esAdmin)
                        {
                            <span class="text-warning fw-bold ms-1" style="font-size: 0.85rem;"><i class="bi bi-shield-fill text-warning"></i> (Admin)</span>
                        }
                    </span>
                </a>

                <form asp-controller="Usuarios" asp-action="Logout" method="post" class="m-0 ms-2">
                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">Salir</button>
                </form>
            </div>
        </div>
    </nav>

    @* CÓDIGO DE CHAT *@
    <div class="chat-fullscreen shadow-lg">
        <div class="text-white d-flex justify-content-between align-items-center px-4 py-3 shadow-sm z-3" style="background-color: rgba(10, 10, 12, 0.95); border-bottom: 1px solid var(--border-glass);">
            <h4 class="fw-bold m-0"><i class="bi bi-chat-left-text-fill text-cyan-neon me-2"></i>Centro de Mensajes</h4>

            <div class="w-25">
                <div class="input-group">
                    <span class="input-group-text bg-dark border-0 rounded-start-pill text-white-50"><i class="bi bi-search"></i></span>
                    <input type="text" id="inputBuscarChat" class="form-control bg-dark text-white border-0 rounded-end-pill" placeholder="Buscar contacto..." style="font-size: 0.95rem;">
                </div>
            </div>
        </div>

        <div class="row g-0 flex-grow-1 overflow-hidden w-100">

            @* 📱 PANEL IZQUIERDO: ÁREA DE CHAT *@
            <div class="col-md-8 d-flex flex-column position-relative h-100" style="background-color: #1a1a1c;">
                @if (Model != null)
                {
                    var elOtro = Model.Usuario1Id == miId ? Model.Usuario2 : Model.Usuario1;

                    // 🟢 LÓGICA DE PERSONALIZACIÓN ÚNICA POR PERFIL 🟢
                    bool soyUsuario1 = Model.Usuario1Id == miId;
                    string miFondo = soyUsuario1 ? Model.FondoPantallaUrlUsuario1 : Model.FondoPantallaUrlUsuario2;
                    string miColor = soyUsuario1 ? Model.ColorBurbujaUsuario1 : Model.ColorBurbujaUsuario2;
                    miColor = miColor ?? "bg-morado text-white";

                    var estiloFondo = !string.IsNullOrEmpty(miFondo)
                    ? $"background-image: url('{miFondo}'); background-size: cover; background-position: center; background-attachment: local;"
                    : "background-color: #1a1a1c;";

                    @* CABECERA DEL CHAT *@
                    <div class="d-flex justify-content-between align-items-center p-3 border-bottom border-secondary border-opacity-25 z-2 shadow-sm flex-shrink-0" style="background-color: #2b2b2b;">
                        <div class="d-flex align-items-center">
                            <a asp-controller="Usuarios" asp-action="VerPerfil" asp-route-id="@elOtro.IdUsuario">
                                <img src="@(!string.IsNullOrEmpty(elOtro.FotoPerfilUrl) ? elOtro.FotoPerfilUrl : "/imagenes/placeholder-perfil.png")"
                                     class="rounded-circle border border-2 border-secondary me-3 object-fit-cover shadow-sm card-hover"
                                     style="width: 45px; height: 45px;">
                            </a>
                            <div>
                                <h5 class="text-white mb-0 fw-bold">@elOtro.Nombre</h5>
                                <small class="text-white-50"><i class="bi bi-geo-alt-fill text-danger"></i> @(elOtro.Ciudad ?? "Sin ciudad")</small>
                            </div>
                        </div>

                        <div class="d-flex gap-2 align-items-center">
                            @if (!string.IsNullOrEmpty(elOtro.Telefono))
                            {
                                <a href="https://wa.me/@elOtro.Telefono.Replace(" ", "").Replace("+", "")" target="_blank"
                                   class="btn btn-dark rounded-circle border border-secondary border-opacity-50 d-flex justify-content-center align-items-center shadow-sm card-hover"
                                   style="width: 40px; height: 40px;" title="WhatsApp">
                                    <i class="bi bi-whatsapp text-success fs-5"></i>
                                </a>
                            }
                            @* 🟢 BOTÓN QUE ABRE EL MODAL 🟢 *@
                            <button type="button" class="btn btn-dark rounded-circle border border-secondary border-opacity-50 d-flex justify-content-center align-items-center shadow-sm card-hover"
                                    style="width: 40px; height: 40px;" data-bs-toggle="modal" data-bs-target="#modalConfigChat" title="Personalizar Chat">
                                <i class="bi bi-three-dots-vertical text-white fs-5"></i>
                            </button>
                        </div>
                    </div>

                    @* ÁREA DE MENSAJES *@
                    <div class="overflow-y-auto p-4 w-100" id="cajaMensajes" style="flex: 1 1 0; min-height: 0; @estiloFondo">
                        @foreach (var m in Model.Mensajes.OrderBy(m => m.FechaEnvio))
                        {
                            bool soyYo = m.RemitenteId == miId;
                            string align = soyYo ? "justify-content-end" : "justify-content-start";
                            string bgBurbuja = soyYo ? miColor : "bg-dark text-white border border-secondary border-opacity-50";

                            <div class="d-flex @align mb-3 position-relative group">
                                <div class="p-2 px-3 shadow-sm rounded-4 @bgBurbuja position-relative" style="max-width: 75%; min-width: 100px;">

                                    @if (esAdmin)
                                    {
                                        <div class="dropdown position-absolute top-0 end-0 mt-1 me-1" style="z-index: 5;">
                                            <i class="bi bi-shield-check text-warning" style="font-size: 0.6rem; cursor:pointer;" data-bs-toggle="dropdown"></i>
                                            <ul class="dropdown-menu dropdown-menu-dark shadow border-secondary">
                                                @if (!string.IsNullOrEmpty(m.Texto))
                                                {
                                                    <li><button class="dropdown-item small" onclick="editarMensaje(@m.IdMensaje, '@m.Texto.Replace("'", "\\'")')">Editar</button></li>
                                                }
                                                <li>
                                                    <form asp-action="EliminarMensaje" method="post" onsubmit="return confirm('¿Eliminar?')">
                                                        <input type="hidden" name="mensajeId" value="@m.IdMensaje" />
                                                        <input type="hidden" name="chatId" value="@Model.IdChat" />
                                                        <button type="submit" class="dropdown-item small text-danger">Eliminar</button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(m.ImagenUrl))
                                    {
                                        <img src="@m.ImagenUrl" class="img-fluid rounded-3 mb-2 chat-imagen" style="max-height: 250px; object-fit: cover; display: block;">
                                    }

                                    @if (!string.IsNullOrEmpty(m.Texto))
                                    {
                                        <p class="mb-1 text-break pe-3" style="font-size: 0.95rem;">@m.Texto</p>
                                    }

                                    <div class="text-end" style="font-size: 0.7rem; opacity: 0.6;">
                                        @if (m.FueEditado)
                                        {
                                            <span class="fst-italic me-1">Editado</span>
                                        }
                                        @m.FechaEnvio.ToString("HH:mm")
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @* ZONA DE ESCRITURA *@
                    <div class="p-3 border-top border-secondary border-opacity-25 z-2" style="background-color: #2b2b2b;">
                        <form asp-action="EnviarMensaje" method="post" id="formEnviar" class="d-flex align-items-center gap-2" enctype="multipart/form-data">
                            <input type="hidden" name="chatId" value="@Model.IdChat" />
                            <label for="inputFotoChat" class="btn text-warning fs-5 p-1 mb-0 card-hover" style="cursor: pointer;"><i class="bi bi-paperclip"></i></label>
                            <input type="file" name="fotoAdjunta" id="inputFotoChat" class="d-none" onchange="mostrarNombreFoto(this)">

                            <div class="flex-grow-1 position-relative">
                                <input type="text" name="texto" id="mensajeTexto" class="form-control rounded-pill border-0 px-3 text-white" placeholder="Escribe un mensaje..." style="background-color: #404040;" autocomplete="off">
                                <small id="nombreFotoPreview" class="position-absolute top-0 start-0 translate-middle-y text-success fw-bold ms-3 bg-dark px-2 rounded-pill d-none border border-success" style="font-size: 0.7rem; margin-top: -10px;">Foto lista</small>
                            </div>

                            <button type="submit" class="btn btn-success rounded-circle text-white shadow-sm" style="width: 42px; height: 42px;" id="btnEnviarMensaje">
                                <i class="bi bi-chevron-right fw-bold fs-5"></i>
                            </button>
                        </form>

                        @* Formulario Editar (Oculto) *@
                        <form asp-action="EditarMensaje" method="post" id="formEditar" class="d-none d-flex align-items-center gap-2 mt-1">
                            <input type="hidden" name="chatId" value="@Model.IdChat" />
                            <input type="hidden" name="mensajeId" id="editMensajeId" />
                            <div class="flex-grow-1"><input type="text" name="nuevoTexto" id="editTexto" class="form-control bg-dark text-white rounded-pill border-primary" required /></div>
                            <button type="button" class="btn btn-secondary btn-sm rounded-pill" onclick="cancelarEdicion()">Cancelar</button>
                            <button type="submit" class="btn btn-primary btn-sm rounded-pill">Guardar</button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="d-flex justify-content-center align-items-center h-100 text-white-50 flex-column">
                        <i class="bi bi-chat-square-dots display-1 mb-3"></i>
                        <h5>Selecciona un chat para comenzar</h5>
                    </div>
                }
            </div>

            @* PANEL DERECHO: CONTACTOS *@
            <div class="col-md-4 border-start border-secondary border-opacity-25 d-flex flex-column h-100" style="background-color: #1e1e24;">
                <div class="p-3 border-bottom border-secondary border-opacity-25 text-white fw-bold">
                    <i class="bi bi-people-fill text-cyan-neon me-2"></i>Contactos
                </div>
                <div class="d-flex flex-column gap-2 overflow-y-auto p-3">
                    @if (misChats != null)
                    {
                        foreach (var c in misChats)
                        {
                            var elOtro = c.Usuario1Id == miId ? c.Usuario2 : c.Usuario1;
                            var activo = (Model != null && Model.IdChat == c.IdChat) ? "active-chat-box" : "";
                            <a asp-action="Index" asp-route-chatId="@c.IdChat" class="text-decoration-none">
                                <div class="btn text-start p-3 text-white border-0 shadow-sm w-100 contact-box @activo" style="background-color: #2b2b2b; border-radius: 12px;">
                                    <div class="d-flex align-items-center">
                                        <img src="@(!string.IsNullOrEmpty(elOtro.FotoPerfilUrl) ? elOtro.FotoPerfilUrl : "/imagenes/placeholder-perfil.png")" class="rounded-circle me-3" style="width: 45px; height: 45px; object-fit: cover;">
                                        <div class="fw-bold">@elOtro.Nombre</div>
                                    </div>
                                </div>
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    @* 🟢 MODAL *@
    @if (Model != null)
    {
        <div class="modal fade" id="modalConfigChat" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-dark text-white border-secondary shadow-lg rounded-4">
                    <div class="modal-header border-bottom border-secondary">
                        <h5 class="modal-title fw-bold"><i class="bi bi-palette-fill text-info me-2"></i>Personalizar mi Chat</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <form asp-controller="Chats" asp-action="PersonalizarChat" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="chatId" value="@Model.IdChat" />
                            <div class="mb-4">
                                <label class="form-label fw-bold">Color de mis burbujas</label>
                                <select name="colorBurbuja" class="form-select bg-secondary text-white border-0">
                                    <option value="bg-morado text-white">🟣 Morado</option>
                                    <option value="bg-primary text-white">🔵 Azul</option>
                                    <option value="bg-success text-white">🟢 Verde</option>
                                    <option value="bg-danger text-white">🔴 Rojo</option>
                                    <option value="bg-warning text-dark">🟡 Amarillo</option>
                                </select>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold">Imagen de Fondo</label>
                                <input type="file" name="imagenFondo" class="form-control bg-secondary text-white border-0" accept="image/*" />
                            </div>
                            <div class="d-grid mt-2">
                                <button type="submit" class="btn btn-info fw-bold text-dark">Guardar Personalización</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        // --- 🔍 LÓGICA DEL BUSCADOR ---
        document.getElementById('inputBuscarChat')?.addEventListener('keyup', function() {
            let filtro = this.value.toLowerCase();
            let contactos = document.querySelectorAll('.contact-box');
            contactos.forEach(contacto => {
                let nombre = contacto.querySelector('.fw-bold').innerText.toLowerCase();
                contacto.parentElement.style.display = nombre.includes(filtro) ? "" : "none";
            });
        });

        // --- 🛠️ FUNCIONES ADMIN ---
        function editarMensaje(id, texto) {
            document.getElementById('editMensajeId').value = id;
            document.getElementById('editTexto').value = texto;
            document.getElementById('formEnviar').classList.add('d-none');
            document.getElementById('formEditar').classList.remove('d-none');
            document.getElementById('editTexto').focus();
        }
        function cancelarEdicion() {
            document.getElementById('formEditar').classList.add('d-none');
            document.getElementById('formEnviar').classList.remove('d-none');
        }

        // --- ✨ UI ---
        function mostrarNombreFoto(input) {
            if (input.files && input.files[0]) document.getElementById('nombreFotoPreview').classList.remove('d-none');
        }

        // --- AUTO SCROLL AL INICIO ---
        document.addEventListener("DOMContentLoaded", () => {
            const caja = document.getElementById("cajaMensajes");
            if(caja) caja.scrollTop = caja.scrollHeight;
            caja?.querySelectorAll('img').forEach(img => { img.onload = () => caja.scrollTop = caja.scrollHeight; });
        });

        // ========================================================
        // 🚀 1. LÓGICA DE TIEMPO REAL CON SIGNALR
        // ========================================================
        const conexion = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

        const chatIdActual = "@Model?.IdChat.ToString()";
        const miPropioId = parseInt("@miId");
        const miColorBurbuja = "@Html.Raw(miColorSignalR)";
        const soyAdmin = @(esAdmin ? "true" : "false"); // 👈 JS ahora sabe que eres Admin

        conexion.start().then(function () {
            if (chatIdActual) {
                conexion.invoke("UnirseAlChat", chatIdActual);
            }
        }).catch(err => console.error("Error SignalR:", err.toString()));

        // ========================================================
        // 🚀 2. INTERCEPTAR EL FORMULARIO (Evita que la página recargue)
        // ========================================================
        document.getElementById("formEnviar")?.addEventListener("submit", async function (e) {
            e.preventDefault();

            let formData = new FormData(this);
            let texto = document.getElementById("mensajeTexto").value;
            let fileInput = document.getElementById("inputFotoChat");

            if (!texto.trim() && fileInput.files.length === 0) return;

            try {
                await fetch(this.action, { method: 'POST', body: formData });
                this.reset();
                document.getElementById('nombreFotoPreview').classList.add('d-none');
                document.getElementById("mensajeTexto").focus();
            } catch (error) {
                console.error("Error al enviar el mensaje:", error);
            }
        });

        // ========================================================
        // 🚀 3. RECIBIR Y PINTAR EL MENSAJE (Con menú Admin)
        // ========================================================
        conexion.on("RecibirMensaje", function (remitenteId, texto, imagenUrl, audioUrl, hora, idMensaje) {

            let esMio = (remitenteId === miPropioId);
            let claseAlineacion = esMio ? "justify-content-end" : "justify-content-start";
            let colorFondo = esMio ? miColorBurbuja : "bg-dark text-white border border-secondary border-opacity-50";

            // 🟢 DIBUJAR EL ESCUDO SI SOY ADMIN
            let menuAdminHtml = "";
            if (soyAdmin && idMensaje) {
                let btnEditar = texto ? `<li><button class="dropdown-item small" onclick="editarMensaje(${idMensaje}, '${texto.replace(/'/g, "\\'")}')">Editar</button></li>` : '';

                menuAdminHtml = `
                <div class="dropdown position-absolute top-0 end-0 mt-1 me-1" style="z-index: 5;">
                    <i class="bi bi-shield-check text-warning" style="font-size: 0.6rem; cursor:pointer;" data-bs-toggle="dropdown"></i>
                    <ul class="dropdown-menu dropdown-menu-dark shadow border-secondary">
                        ${btnEditar}
                        <li>
                            <form action="/Chats/EliminarMensaje" method="post" onsubmit="return confirm('¿Eliminar?')">
                                <input type="hidden" name="mensajeId" value="${idMensaje}" />
                                <input type="hidden" name="chatId" value="${chatIdActual}" />
                                <button type="submit" class="dropdown-item small text-danger">Eliminar</button>
                            </form>
                        </li>
                    </ul>
                </div>`;
            }

            let mensajeHtml = `
            <div class="d-flex ${claseAlineacion} mb-3 position-relative group">
                <div class="p-2 px-3 shadow-sm rounded-4 ${colorFondo} position-relative" style="max-width: 75%; min-width: 100px;">
                    ${menuAdminHtml}
            `;

            if (imagenUrl) mensajeHtml += `<img src="${imagenUrl}" class="img-fluid rounded-3 mb-2 chat-imagen" style="max-height: 250px; object-fit: cover; display: block;" />`;
            if (texto) mensajeHtml += `<p class="mb-1 text-break pe-3" style="font-size: 0.95rem;">${texto}</p>`;
            if (audioUrl) mensajeHtml += `<audio controls src="${audioUrl}" class="mt-2" style="max-width: 200px;"></audio>`;

            mensajeHtml += `
                    <div class="text-end" style="font-size: 0.7rem; opacity: 0.6;">
                        ${hora}
                    </div>
                </div>
            </div>`;

            // Dibuja el globo de texto
            document.getElementById("cajaMensajes").innerHTML += mensajeHtml;
            var caja = document.getElementById("cajaMensajes");
            caja.scrollTop = caja.scrollHeight;
        });
    </script>
</body>
</html>
