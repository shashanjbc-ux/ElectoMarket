@model ElectoMarket.Models.Chat
@using Microsoft.AspNetCore.Http
@using Microsoft.EntityFrameworkCore
@using ElectoMarket.Data
@inject IHttpContextAccessor HttpContextAccessor
@inject ApplicationDbContext _context

@{
    Layout = null; //  Desconecta el layout blanco por defecto

    ViewData["Title"] = "Mis Chats";
    var misChats = ViewBag.MisChats as List<ElectoMarket.Models.Chat>;
    int miId = ViewBag.MiId ?? 0;
    int? miRol = HttpContextAccessor.HttpContext?.Session.GetInt32("UsuarioRol");
    bool esAdmin = miRol == 1;

    // Variables para la Navbar
    var uNombre = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioNombre") ?? "Usuario";
    var uFoto = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioFoto");

    //  CONTADOR DE MENSAJES SIN VER PARA LA NAVBAR
    int mensajesSinLeerNavbar = 0;
    if (miId > 0)
    {
        mensajesSinLeerNavbar = _context.Mensajes
            .Include(m => m.Chat)
            .Count(m => !m.Leido && m.RemitenteId != miId && (m.Chat.Usuario1Id == miId || m.Chat.Usuario2Id == miId));
    }

    // Lógica para SignalR (Color del usuario)
    string miColorSignalR = "bg-primary text-white"; 
    if (Model != null)
    {
        bool soyYo = Model.Usuario1Id == miId;
        miColorSignalR = soyYo ? Model.ColorBurbujaUsuario1 : Model.ColorBurbujaUsuario2;
        miColorSignalR = miColorSignalR ?? "bg-morado text-white";
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mis Chats - ElectroMarket</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
            :root {
                --bg-dark: #08080a;
                --glass-bg: rgba(18, 18, 22, 0.85);
                --border-glass: rgba(255, 255, 255, 0.1);
                --morado-neon: #7c4dff;
                --cyan-neon: #00d2ff;
                --verde-neon: #00ff88;
            }

            body {
                background-color: var(--bg-dark);
                color: white;
                font-family: 'Inter', system-ui, sans-serif;
                height: 100vh;
                margin: 0;
                display: flex;
                flex-direction: column;
                overflow: hidden;
            }

            .tech-bg {
                position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1;
                background-image: radial-gradient(circle at 10% 20%, rgba(124, 77, 255, 0.12) 0%, transparent 40%), radial-gradient(circle at 90% 80%, rgba(0, 210, 255, 0.1) 0%, transparent 40%);
            }

            .navbar-custom { background: rgba(10, 10, 12, 0.9); backdrop-filter: blur(15px); border-bottom: 1px solid var(--border-glass); padding: 12px 0; flex-shrink: 0; }
            .nav-link-tech { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: 0.3s; display: flex; align-items: center; }
            .nav-link-tech:hover { color: var(--cyan-neon); text-shadow: 0 0 10px var(--cyan-neon); }
            
            .chat-icon-btn { position: relative; color: white; font-size: 1.2rem; transition: 0.3s; }
            
            .hover-white:hover { color: white !important; text-shadow: 0 0 8px rgba(255, 255, 255, 0.5); transition: 0.2s; }

            .chat-fullscreen { flex-grow: 1; display: flex; flex-direction: column; width: 100%; }
            .contact-box { transition: 0.2s; opacity: 0.8; }
            .active-chat-box { border-left: 5px solid var(--cyan-neon) !important; background-color: #1a1a1a !important; opacity: 1; }
            
            ::-webkit-scrollbar { width: 6px; }
            ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 10px; }

            /* Estilos para Modal Oscuro */
            .modal-content-dark { background-color: #1a1a1c; color: white; border: 1px solid var(--border-glass); }
            .modal-header-dark { border-bottom: 1px solid var(--border-glass); }
            .modal-footer-dark { border-top: 1px solid var(--border-glass); }

            /* Estilo para la alerta de error */
            .border-error-alert { border: 2px solid #ff4d4d !important; box-shadow: 0 0 20px rgba(255, 77, 77, 0.4) !important; border-radius: 20px !important; }
            
            /* Colores de Burbuja */
            .bg-morado { background-color: #7c4dff !important; }
            .bg-verde { background-color: #00ff88 !important; color: #000 !important; }
            .bg-rojo { background-color: #ff4d4d !important; }
            .bg-azul { background-color: #00d2ff !important; color: #000 !important; }
            .bg-naranja { background-color: #ff9f43 !important; }
    </style>
</head>
<body>

    <div class="tech-bg"></div>

    @* 🔊 REPRODUCTORES DE SONIDO *@
    <audio id="notificacionSonido" preload="auto">
        <source src="https://assets.mixkit.co/active_storage/sfx/2354/2354-preview.mp3" type="audio/mpeg">
    </audio>

    @* NAVBAR PREMIUM *@
    <nav class="navbar-custom z-3">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center text-decoration-none">
                    <img src="/imagenes/Logo/Logo.jpg" alt="Logo" style="height: 40px; width: 40px; border-radius: 50%; background-color: white;">
                    <span class="text-white fw-bold fs-5 ms-2">ElectroMarket</span>
                </a>

                <div class="ms-5 d-flex gap-4">
                    <a asp-controller="Productos" asp-action="Index" class="nav-link-tech"><i class="bi bi-shop me-1"></i> Catálogo</a>
                    @if (esAdmin)
                    {
                        <a asp-controller="Home" asp-action="Index" class="nav-link-tech"><i class="bi bi-shield-lock me-1"></i> Inicio</a>
                        <a asp-controller="Usuarios" asp-action="ListadoUsuarios" class="nav-link-tech"><i class="bi bi-people me-1"></i> Usuarios</a>
                        <a asp-controller="Productos" asp-action="Gestionar" class="nav-link-tech"><i class="bi bi-box-seam me-1"></i> Productos</a>
                    }
                </div>
            </div>

            <div class="d-flex align-items-center gap-4">
                <a asp-controller="Chats" asp-action="Index" class="chat-icon-btn position-relative" title="Mis Mensajes">
                    <i class="bi bi-chat-dots"></i>
                    @if (mensajesSinLeerNavbar > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow-sm" style="font-size: 0.65rem; padding: 0.35em 0.65em; transform: translate(-20%, -10%) !important;">
                            @(mensajesSinLeerNavbar > 99 ? "99+" : mensajesSinLeerNavbar.ToString())
                        </span>
                    }
                </a>

                <a asp-controller="Usuarios" asp-action="Perfil" class="d-flex align-items-center text-decoration-none">
                    <img src="@(!string.IsNullOrEmpty(uFoto) ? uFoto : "/imagenes/placeholder-perfil.png")" class="rounded-circle border border-secondary me-2" style="width: 35px; height: 35px; object-fit: cover;">
                    <span class="text-white-50 small hover-white">Hola, <span class="fw-bold text-white">@uNombre</span></span>
                </a>

                <form asp-controller="Usuarios" asp-action="Logout" method="post" class="m-0 ms-2">
                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">Salir</button>
                </form>
            </div>
        </div>
    </nav>

    <div class="chat-fullscreen shadow-lg">
        @if (misChats != null && (misChats.Any() || Model != null))
        {
            <div class="text-white d-flex justify-content-between align-items-center px-4 py-3 shadow-sm z-3" style="background-color: rgba(10, 10, 12, 0.95); border-bottom: 1px solid var(--border-glass);">
                <h4 class="fw-bold m-0"><i class="bi bi-chat-left-text-fill text-cyan-neon me-2"></i>Centro de Mensajes</h4>
                <div class="w-25">
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-0 rounded-start-pill text-white-50"><i class="bi bi-search"></i></span>
                        <input type="text" id="inputBuscarChat" class="form-control bg-dark text-white border-0 rounded-end-pill" placeholder="Buscar contacto..." style="font-size: 0.95rem;">
                    </div>
                </div>
            </div>

            <div class="row g-0 flex-grow-1 overflow-hidden w-100">
                <div class="col-md-8 d-flex flex-column position-relative h-100" style="background-color: #1a1a1c;">
                    @if (Model != null)
                    {
                        var elOtro = Model.Usuario1Id == miId ? Model.Usuario2 : Model.Usuario1;
                        bool soyUsuario1 = Model.Usuario1Id == miId;
                        string miFondo = soyUsuario1 ? Model.FondoPantallaUrlUsuario1 : Model.FondoPantallaUrlUsuario2;
                        string miColor = soyUsuario1 ? Model.ColorBurbujaUsuario1 : Model.ColorBurbujaUsuario2;
                        miColor = miColor ?? "bg-morado text-white";

                        var estiloFondo = !string.IsNullOrEmpty(miFondo) ? $"background-image: url('{miFondo}'); background-size: cover; background-position: center;" : "background-color: #1a1a1c;";

                        <div class="d-flex justify-content-between align-items-center p-3 border-bottom border-secondary border-opacity-25 z-2 shadow-sm flex-shrink-0" style="background-color: #2b2b2b;">
                            <div class="d-flex align-items-center">
                                <a asp-controller="Usuarios" asp-action="VerPerfil" asp-route-id="@elOtro.IdUsuario">
                                    <img src="@(!string.IsNullOrEmpty(elOtro.FotoPerfilUrl) ? elOtro.FotoPerfilUrl : "/imagenes/placeholder-perfil.png")" class="rounded-circle border border-2 border-secondary me-3 object-fit-cover shadow-sm" style="width: 45px; height: 45px;">
                                </a>
                                <div>
                                    <h5 class="text-white mb-0 fw-bold">@elOtro.Nombre</h5>
                                    <small class="text-white-50">
                                        @if (elOtro.UltimaConexion.HasValue)
                                        {
                                            var diferencia = DateTime.Now - elOtro.UltimaConexion.Value;
                                            if (diferencia.TotalMinutes < 5) { <span class="text-success fw-bold"><i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i> En línea</span> }
                                            else { <span>Visto por última vez: @elOtro.UltimaConexion.Value.ToString("dd/MM HH:mm")</span> }
                                        }
                                        else { <span>Desconectado</span> }
                                    </small>
                                </div>
                            </div>
                            
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-secondary btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;" data-bs-toggle="modal" data-bs-target="#modalPersonalizar" title="Personalizar Chat">
                                    <i class="bi bi-palette"></i>
                                </button>

                                <form asp-action="OcultarMiChat" method="post" id="formOcultarChat" class="m-0">
                                    <input type="hidden" name="chatId" value="@Model.IdChat" />
                                    <button type="button" class="btn btn-outline-danger btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;" onclick="confirmarEliminarChat()" title="Eliminar Chat">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div class="overflow-y-auto p-4 w-100" id="cajaMensajes" style="flex: 1 1 0; min-height: 0; @estiloFondo">
                            @foreach (var m in Model.Mensajes.OrderBy(m => m.FechaEnvio))
                            {
                                bool soyYo = m.RemitenteId == miId;
                                string align = soyYo ? "justify-content-end" : "justify-content-start";
                                string bgBurbuja = soyYo ? miColor : "bg-dark text-white border border-secondary border-opacity-50";

                                <div class="d-flex @align mb-3">
                                    <div class="p-2 px-3 shadow-sm rounded-4 @bgBurbuja" style="max-width: 75%; min-width: 100px;">
                                        @if (!string.IsNullOrEmpty(m.ImagenUrl)) { <img src="@m.ImagenUrl" class="img-fluid rounded-3 mb-2" style="max-height: 250px; display: block;"> }
                                        @if (!string.IsNullOrEmpty(m.Texto)) { <p class="mb-1 text-break">@m.Texto</p> }

                                        <div class="text-end" style="font-size: 0.7rem; opacity: 0.6;">
                                            @m.FechaEnvio.ToString("HH:mm")
                                            @if (soyYo)
                                            {
                                                @if (m.Leido) { <i class="bi bi-check-all text-info ms-1 icono-visto" title="Leído"></i> }
                                                else { <i class="bi bi-check ms-1 icono-visto" title="Enviado"></i> }
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="p-3 border-top border-secondary border-opacity-25" style="background-color: #2b2b2b;">
                            <div id="imagePreviewContainer" class="d-none mb-2 position-relative d-inline-block ms-2">
                                <img id="imagePreview" src="" class="rounded shadow-sm" style="max-height: 120px; object-fit: cover; border: 2px solid var(--border-glass);" />
                                <button type="button" class="btn btn-sm btn-danger position-absolute top-0 start-100 translate-middle rounded-circle shadow" onclick="removeImage()" style="width: 25px; height: 25px; padding: 0; display: flex; align-items: center; justify-content: center;">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>

                            <form asp-action="EnviarMensaje" method="post" id="formEnviar" class="d-flex align-items-center gap-2" enctype="multipart/form-data">
                                <input type="hidden" name="chatId" value="@Model.IdChat" />
                                <input type="file" name="imagen" id="imageInput" accept="image/*" class="d-none" onchange="previewImage(event)" />

                                <button type="button" class="btn text-secondary p-2" onclick="document.getElementById('imageInput').click()" style="transition: 0.2s;">
                                    <i class="bi bi-image fs-5 text-white-50 hover-white"></i>
                                </button>

                                <input type="text" name="texto" id="mensajeTexto" class="form-control rounded-pill border-0 px-3 text-white" placeholder="Escribe un mensaje..." style="background-color: #404040;" autocomplete="off">
                                
                                <button type="submit" class="btn btn-success rounded-circle" style="width: 42px; height: 42px;"><i class="bi bi-chevron-right"></i></button>
                            </form>
                        </div>

                        <div class="modal fade" id="modalPersonalizar" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content modal-content-dark">
                                    <div class="modal-header modal-header-dark">
                                        <h5 class="modal-title fw-bold text-cyan-neon"><i class="bi bi-palette"></i> Personalizar Chat</h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <form asp-action="PersonalizarChat" method="post" enctype="multipart/form-data">
                                        <div class="modal-body p-4">
                                            <input type="hidden" name="chatId" value="@Model.IdChat" />
                                            
                                            <div class="mb-4">
                                                <label class="form-label text-white-50 small mb-2">Color de tus mensajes</label>
                                                <div class="d-flex gap-2">
                                                    <div class="form-check p-0">
                                                        <input type="radio" name="colorBurbuja" value="bg-primary text-white" class="btn-check" id="col1" @(miColor == "bg-primary text-white" ? "checked" : "")>
                                                        <label class="btn btn-outline-primary rounded-circle p-3" for="col1"></label>
                                                    </div>
                                                    <div class="form-check p-0">
                                                        <input type="radio" name="colorBurbuja" value="bg-morado text-white" class="btn-check" id="col2" @(miColor == "bg-morado text-white" ? "checked" : "")>
                                                        <label class="btn btn-outline-secondary rounded-circle p-3 bg-morado border-0" for="col2"></label>
                                                    </div>
                                                    <div class="form-check p-0">
                                                        <input type="radio" name="colorBurbuja" value="bg-verde text-dark" class="btn-check" id="col3" @(miColor == "bg-verde text-dark" ? "checked" : "")>
                                                        <label class="btn btn-outline-success rounded-circle p-3 bg-verde border-0" for="col3"></label>
                                                    </div>
                                                    <div class="form-check p-0">
                                                        <input type="radio" name="colorBurbuja" value="bg-rojo text-white" class="btn-check" id="col4" @(miColor == "bg-rojo text-white" ? "checked" : "")>
                                                        <label class="btn btn-outline-danger rounded-circle p-3 bg-rojo border-0" for="col4"></label>
                                                    </div>
                                                    <div class="form-check p-0">
                                                        <input type="radio" name="colorBurbuja" value="bg-azul text-dark" class="btn-check" id="col5" @(miColor == "bg-azul text-dark" ? "checked" : "")>
                                                        <label class="btn btn-outline-info rounded-circle p-3 bg-azul border-0" for="col5"></label>
                                                    </div>
                                                </div>
                                            </div>

                                            <div>
                                                <label class="form-label text-white-50 small mb-2">Fondo de pantalla</label>
                                                <input type="file" name="imagenFondo" id="fondoInput" class="form-control form-control-sm bg-dark text-white border-secondary" accept="image/*" onchange="validarFondo(event)">
                                                <small class="text-muted mt-1 d-block">Sube una imagen para tu fondo de chat privado.</small>
                                            </div>
                                        </div>
                                        <div class="modal-footer modal-footer-dark">
                                            <button type="button" class="btn btn-secondary btn-sm rounded-pill px-3" data-bs-dismiss="modal">Cancelar</button>
                                            <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4">Guardar Cambios</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                    }
                    else
                    {
                        <div class="d-flex justify-content-center align-items-center h-100 text-white-50 flex-column"><i class="bi bi-chat-square-dots display-1 mb-3"></i><h5>Selecciona un chat para comenzar</h5></div>
                    }
                </div>

                <div class="col-md-4 border-start border-secondary border-opacity-25 d-flex flex-column h-100" style="background-color: #1e1e24;">
                    <div class="p-3 border-bottom border-secondary text-white fw-bold">Contactos</div>
                    <div class="d-flex flex-column gap-2 overflow-y-auto p-3">
                        @if (misChats != null)
                        {
                            foreach (var c in misChats)
                            {
                                var elOtroC = c.Usuario1Id == miId ? c.Usuario2 : c.Usuario1;
                                var activo = (Model != null && Model.IdChat == c.IdChat) ? "active-chat-box" : "";
                                <a asp-action="Index" asp-route-chatId="@c.IdChat" class="text-decoration-none">
                                    <div class="btn text-start p-3 text-white border-0 w-100 contact-box @activo" style="background-color: #2b2b2b; border-radius: 12px;">
                                        <div class="d-flex align-items-center">
                                            <img src="@(!string.IsNullOrEmpty(elOtroC.FotoPerfilUrl) ? elOtroC.FotoPerfilUrl : "/imagenes/placeholder-perfil.png")" class="rounded-circle me-3" style="width: 45px; height: 45px; object-fit: cover;">
                                            <div class="fw-bold">@elOtroC.Nombre</div>
                                        </div>
                                    </div>
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="d-flex flex-column justify-content-center align-items-center text-center w-100 h-100" style="background: rgba(255,255,255,0.02);">
                <div class="mb-4" style="width: 120px; height: 120px; border-radius: 50%; background: rgba(124, 77, 255, 0.1); border: 2px dashed #7c4dff; display: flex; align-items: center; justify-content: center;"><i class="bi bi-chat-square-heart text-white" style="font-size: 3.5rem;"></i></div>
                <h2 class="fw-bold text-white mb-3">Tu centro de mensajes está vacío</h2>
                <a asp-controller="Productos" asp-action="Index" class="btn btn-primary px-5 py-3" style="border-radius: 15px;">Ir al Catálogo</a>
            </div>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        //  BUSCADOR DE CONTACTOS EN TIEMPO REAL 
        document.getElementById("inputBuscarChat")?.addEventListener("input", function() {
            // Convertimos lo que escribes a minúsculas para buscar sin problemas
            const textoBuscado = this.value.toLowerCase();
            
            // Seleccionamos todos los recuadros de contactos de la barra lateral derecha
            const listaContactos = document.querySelectorAll(".col-md-4 .overflow-y-auto a.text-decoration-none");

            listaContactos.forEach(contacto => {
                // Buscamos el nombre de la persona dentro de ese recuadro
                const nombreContacto = contacto.querySelector(".fw-bold").textContent.toLowerCase();
                
                // Si el nombre incluye lo que escribiste, lo mostramos. Si no, lo ocultamos.
                if (nombreContacto.includes(textoBuscado)) {
                    contacto.style.display = ""; // Vuelve a su estado normal
                } else {
                    contacto.style.display = "none"; // Se oculta
                }
            });
        });

        // CONFIRMAR ELIMINACIÓN DE CHAT
        function confirmarEliminarChat() {
            Swal.fire({
                title: '¿Eliminar este chat?',
                text: "Desaparecerá de tu lista, pero la otra persona aún podrá verlo. Si te vuelve a escribir, reaparecerá.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ff4d4d',
                cancelButtonColor: '#404040',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar',
                background: '#161618',
                color: '#fff',
                customClass: { popup: 'border-error-alert' }
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('formOcultarChat').submit();
                }
            });
        }

        // VALIDAR FONDO DE PANTALLA (Para evitar PDFs o Excel)
        function validarFondo(event) {
            const file = event.target.files[0];
            if (file) {
                if (!file.type.startsWith('image/')) {
                    Swal.fire({
                        title: '<span style="color: #ff4d4d; font-weight: 800;">ARCHIVO NO PERMITIDO</span>',
                        html: '<span style="color: #aaa; font-size: 0.95rem;">Para el fondo de pantalla solo se permiten imágenes (PNG, JPG, etc.).</span>',
                        icon: 'warning',
                        background: '#161618',
                        color: '#fff',
                        confirmButtonColor: '#7c4dff',
                        confirmButtonText: 'Entendido',
                        customClass: { popup: 'border-error-alert' }
                    });
                    event.target.value = ''; // Limpiar el input para que no suba el PDF
                }
            }
        }

        // PREVISUALIZAR IMÁGENES AL ENVIAR MENSAJE
        function previewImage(event) {
            const file = event.target.files[0];
            
            if (file) {
                if (!file.type.startsWith('image/')) {
                    Swal.fire({
                        title: '<span style="color: #ff4d4d; font-weight: 800;">ARCHIVO NO PERMITIDO</span>',
                        html: '<span style="color: #aaa; font-size: 0.95rem;">Por favor, selecciona solo imágenes (Fotos, PNG, JPG). No se permiten documentos de Word, Excel ni PDFs.</span>',
                        icon: 'warning',
                        background: '#161618',
                        color: '#fff',
                        confirmButtonColor: '#7c4dff',
                        confirmButtonText: 'Entendido',
                        customClass: { popup: 'border-error-alert' }
                    });
                    removeImage(); 
                    return; 
                }

                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('imagePreview').src = e.target.result;
                    document.getElementById('imagePreviewContainer').classList.remove('d-none');
                    document.getElementById('mensajeTexto').focus(); 
                }
                reader.readAsDataURL(file);
            }
        }

        function removeImage() {
            document.getElementById('imageInput').value = '';
            document.getElementById('imagePreview').src = '';
            document.getElementById('imagePreviewContainer').classList.add('d-none');
        }

        // Configuración de SignalR y Chat
        const conexion = new signalR.HubConnectionBuilder().withUrl("/chatHub").build();
        const chatIdActual = "@Model?.IdChat.ToString()";
        const miPropioId = parseInt("@miId");
        const miColorBurbuja = "@Html.Raw(miColorSignalR)";

        conexion.start().then(() => { if (chatIdActual) conexion.invoke("UnirseAlChat", chatIdActual); });

        conexion.on("MensajesLeidos", function (chatIdRecibido) {
            if (chatIdRecibido.toString() === chatIdActual) {
                document.querySelectorAll(".icono-visto").forEach(icon => {
                    icon.classList.remove("bi-check");
                    icon.classList.add("bi-check-all", "text-info");
                });
            }
        });

        document.getElementById("formEnviar")?.addEventListener("submit", async function (e) {
            e.preventDefault();
            
            const texto = document.getElementById("mensajeTexto").value.trim();
            const tieneImagen = document.getElementById("imageInput").files.length > 0;
            
            if (!texto && !tieneImagen) return;

            try { 
                await fetch(this.action, { method: 'POST', body: new FormData(this) }); 
                this.reset(); 
                removeImage(); 
            } catch (error) { 
                console.error(error); 
            }
        });

        conexion.on("RecibirMensaje", function (remitenteId, texto, imagenUrl, audioUrl, hora, idMensaje) {
            let esMio = (remitenteId === miPropioId);
            
            if (!esMio) {
                let sonido = document.getElementById("notificacionSonido");
                sonido.play().catch(error => console.log("Audio bloqueado: " + error));
            }

            let alineacion = esMio ? "justify-content-end" : "justify-content-start";
            let color = esMio ? miColorBurbuja : "bg-dark text-white border border-secondary border-opacity-50";
            let palomita = esMio ? '<i class="bi bi-check ms-1 icono-visto" title="Enviado"></i>' : '';

            let html = `<div class="d-flex ${alineacion} mb-3"><div class="p-2 px-3 shadow-sm rounded-4 ${color}" style="max-width: 75%; min-width: 100px;">`;
            if (imagenUrl) html += `<img src="${imagenUrl}" class="img-fluid rounded-3 mb-2" style="max-height: 250px; display: block;" />`;
            if (texto) html += `<p class="mb-1 text-break">${texto}</p>`;
            html += `<div class="text-end" style="font-size: 0.7rem; opacity: 0.6;">${hora} ${palomita}</div></div></div>`;

            document.getElementById("cajaMensajes").innerHTML += html;
            const caja = document.getElementById("cajaMensajes");
            caja.scrollTop = caja.scrollHeight;
        });
    </script>
</body>
</html>