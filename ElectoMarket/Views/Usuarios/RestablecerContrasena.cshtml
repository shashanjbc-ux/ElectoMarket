@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Nueva Clave - ElectroMarket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            background-color: #0a0a0c;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            font-family: 'Inter', sans-serif;
        }

        .card-custom {
            background: #121214;
            padding: 35px;
            border-radius: 20px;
            width: 420px;
            border: 1px solid #27272a;
        }

        .btn-morado {
            background: #7c4dff;
            color: white;
            border-radius: 12px;
            border: none;
            padding: 12px;
            font-weight: bold;
            width: 100%;
        }

        .form-control {
            background: #1a1a1c;
            border: 1px solid #27272a;
            color: white;
        }

        .requisitos {
            background: rgba(255, 255, 255, 0.03);
            padding: 15px;
            border-radius: 12px;
            font-size: 0.75rem;
            border: 1px solid #27272a;
        }

        .req-item {
            color: #a1a1aa;
            margin-bottom: 4px;
            display: flex;
            align-items: center;
        }

            .req-item i {
                font-size: 8px;
                margin-right: 8px;
                color: #7c4dff;
            }

        .input-group-text {
            background: #1a1a1c;
            border: 1px solid #27272a;
            color: #a1a1aa;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <div class="card-custom">
        <h3 class="fw-bold text-center mb-4">Nueva <span style="color:#7c4dff">Contraseña</span></h3>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger small border-0 mb-3" style="background: rgba(255, 59, 48, 0.1); color: #ff3b30;">@ViewBag.Error</div>
        }

        <div class="requisitos mb-4">
            <div class="fw-bold mb-2 small text-white">Requisitos de seguridad:</div>
            <div class="req-item"><i class="bi bi-circle-fill"></i> Mínimo 6 caracteres</div>
            <div class="req-item"><i class="bi bi-circle-fill"></i> Al menos una Mayúscula</div>
            <div class="req-item"><i class="bi bi-circle-fill"></i> Al menos un Número</div>
            <div class="req-item"><i class="bi bi-circle-fill"></i> Un carácter especial ($, #, @@, *)</div>
        </div>

        <form asp-action="RestablecerContrasena" method="post">
            <input type="hidden" name="correo" value="@ViewBag.Correo" />

            <label class="small text-white-50 mb-1">Nueva Contraseña</label>
            <div class="input-group mb-3">
                <input type="password" id="pass1" name="nuevaClave" class="form-control" required>
                <span class="input-group-text" onclick="togglePass('pass1')"><i class="bi bi-eye"></i></span>
            </div>

            <label class="small text-white-50 mb-1">Confirmar Contraseña</label>
            <div class="input-group mb-4">
                <input type="password" id="pass2" name="confirmarClave" class="form-control" required>
                <span class="input-group-text" onclick="togglePass('pass2')"><i class="bi bi-eye"></i></span>
            </div>

            <button type="submit" class="btn btn-morado shadow-sm">Actualizar Contraseña</button>
        </form>
    </div>

    <script>
        function togglePass(id) {
            const input = document.getElementById(id);
            const icon = input.nextElementSibling.querySelector('i');
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = "password";
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
    </script>
</body>
</html>
