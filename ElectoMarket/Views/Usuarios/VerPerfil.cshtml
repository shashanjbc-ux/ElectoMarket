@model ElectoMarket.Models.Usuario
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    Layout = null; // Diseño independiente premium
    ViewData["Title"] = "Perfil de " + Model.Nombre;
    
    // 🟢 Lógica original preservada 🟢
    var miId = HttpContextAccessor.HttpContext?.Session.GetInt32("UsuarioId");
    var productos = ViewBag.ProductosPublicos as List<ElectoMarket.Models.Producto>;

    // Variables para la Navbar
    var uNombre = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioNombre") ?? "Usuario";
    var uFoto = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioFoto");
    var miRol = HttpContextAccessor.HttpContext?.Session.GetInt32("UsuarioRol");
    bool esAdmin = miRol == 1;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ElectroMarket</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --bg-main: #08080a;
            --bg-card: rgba(18, 18, 20, 0.75);
            --border-color: rgba(255, 255, 255, 0.1);
            --text-main: #ffffff;
            --text-muted: #a1a1aa;
            --morado: #7c4dff;
            --morado-glow: rgba(124, 77, 255, 0.25);
            --cyan-glow: rgba(0, 210, 255, 0.15);
            --cyan-neon: #00d2ff;
            --verde-neon: #00ff88;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            font-family: 'Inter', system-ui, sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        /* --- FONDO TECH --- */
        .tech-bg {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            z-index: -1;
            background-image: radial-gradient(circle at 10% 20%, rgba(124, 77, 255, 0.12) 0%, transparent 40%),
                              radial-gradient(circle at 90% 80%, rgba(0, 210, 255, 0.1) 0%, transparent 40%);
        }
        
        .glow-orb-1 {
            position: absolute; top: 10%; left: 20%; width: 400px; height: 400px;
            background: radial-gradient(circle, var(--morado-glow) 0%, transparent 70%);
            z-index: -1; filter: blur(50px); animation: float 6s ease-in-out infinite;
        }
        .glow-orb-2 {
            position: absolute; bottom: 10%; right: 20%; width: 350px; height: 350px;
            background: radial-gradient(circle, var(--cyan-glow) 0%, transparent 70%);
            z-index: -1; filter: blur(50px); animation: float 8s ease-in-out infinite reverse;
        }

        @@keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-30px); }
            100% { transform: translateY(0px); }
        }

        /* --- NAVBAR SUPERIOR --- */
        .navbar-main {
            background-color: rgba(10, 10, 12, 0.9);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border-color);
            padding: 12px 0;
            flex-shrink: 0;
        }
        .nav-link-tech { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: 0.3s; display: flex; align-items: center; }
        .nav-link-tech:hover { color: var(--cyan-neon); text-shadow: 0 0 10px var(--cyan-neon); }
        .hover-white:hover { color: white !important; transition: 0.2s; }
        .chat-icon-btn { position: relative; color: white; font-size: 1.2rem; transition: 0.3s; }

        /* --- CONTENEDOR PRINCIPAL GLASSMORPHISM --- */
        .admin-container {
            flex-grow: 1;
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .public-profile-card {
            background: var(--bg-card);
            backdrop-filter: blur(20px);
            border: 2px solid;
            border-image: linear-gradient(135deg, #7c4dff 0%, #00d2ff 100%) 1;
            border-radius: 24px;
            width: 100%;
            max-width: 1100px;
            padding: 40px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.7);
            position: relative;
        }

        .edit-profile-title { font-size: 2rem; font-weight: 800; letter-spacing: -1px; margin-bottom: 10px; }
        .form-section-title { font-size: 1.1rem; font-weight: 700; color: #b388ff; margin-bottom: 20px; border-left: 3px solid var(--morado); padding-left: 10px; }

        /* --- FOTO Y DETALLES DE PERFIL IZQUIERDO --- */
        .profile-main-pic {
            width: 160px; height: 160px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid var(--morado);
            padding: 6px;
            box-shadow: 0 0 30px var(--morado-glow);
            margin-bottom: 20px;
            background: rgba(255,255,255,0.05);
        }

        /* --- LISTA DE PRODUCTOS DERECHO --- */
        .equipment-list { margin-top: 15px; }
        .equipment-item {
            background: rgba(255,255,255,0.02);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 18px;
            margin-bottom: 15px;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .equipment-item:hover {
            background: rgba(255,255,255,0.05);
            border-color: var(--cyan-neon);
            transform: translateX(10px);
            box-shadow: 0 5px 15px rgba(0, 210, 255, 0.1);
        }
        .equipment-pic { width: 70px; height: 70px; object-fit: cover; border-radius: 12px; margin-right: 18px; border: 1px solid var(--border-color); background: rgba(255,255,255,0.05); }
        .price-text { color: var(--verde-neon); font-weight: 700; font-size: 1.1rem; }

        /* --- BOTONES DE ACCIÓN PUBLICOS --- */
        .btn-contact-custom {
            background: linear-gradient(135deg, var(--morado), #00d2ff);
            color: white; border: none; border-radius: 12px; padding: 12px 20px;
            font-weight: 700; font-size: 0.95rem; cursor: pointer; transition: 0.3s;
            width: 100%; box-shadow: 0 10px 25px rgba(124, 77, 255, 0.4);
            text-decoration: none; display: inline-flex; justify-content: center; align-items: center;
        }
        .btn-contact-custom:hover { transform: translateY(-3px); box-shadow: 0 15px 35px rgba(124, 77, 255, 0.6); color: white; }

        .btn-whatsapp-custom {
            background: linear-gradient(135deg, #128C7E, #25D366);
            color: white; border: none; border-radius: 12px; padding: 12px 20px;
            font-weight: 700; font-size: 0.95rem; cursor: pointer; transition: 0.3s;
            width: 100%; box-shadow: 0 10px 25px rgba(37, 211, 102, 0.3);
            text-decoration: none; display: inline-flex; justify-content: center; align-items: center;
        }
        .btn-whatsapp-custom:hover { transform: translateY(-3px); box-shadow: 0 15px 35px rgba(37, 211, 102, 0.5); color: white; }

        .btn-view-custom {
            background-color: transparent; border: 1px solid var(--border-color);
            color: var(--cyan-neon); border-radius: 12px; padding: 12px 20px;
            font-weight: 600; font-size: 0.9rem; text-decoration: none; transition: 0.3s;
        }
        .btn-view-custom:hover { border-color: var(--cyan-neon); background: rgba(0, 210, 255, 0.05); color: var(--cyan-neon); transform: translateY(-3px); }

        .profile-subtitle-cyan { font-size: 1rem; color: var(--cyan-neon); margin-bottom: 20px; }
    </style>
</head>
<body>

    <div class="tech-bg"></div>
    <div class="glow-orb-1"></div>
    <div class="glow-orb-2"></div>

    @* NAVBAR PREMIUM *@
    <nav class="navbar-main sticky-top shadow-sm z-3">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center text-decoration-none">
                    <img src="/imagenes/Logo/Logo.jpg" alt="Logo" style="height: 40px; width: 40px; object-fit: contain; border-radius: 50%;">
                    <span class="text-white fw-bold fs-5 ms-2">ElectroMarket</span>
                </a>
                
                <div class="ms-5 d-flex gap-4">
                    <a asp-controller="Productos" asp-action="Index" class="nav-link-tech"><i class="bi bi-shop me-1"></i> Catálogo</a>
                    @if (esAdmin) { 
                        <a asp-controller="Home" asp-action="Index" class="nav-link-tech"><i class="bi bi-shield-lock me-1"></i> Inicio</a>
                        <a asp-controller="Usuarios" asp-action="ListadoUsuarios" class="nav-link-tech"><i class="bi bi-people me-1"></i> Gestión Usuarios</a>
                        <a asp-controller="Productos" asp-action="Gestionar" class="nav-link-tech"><i class="bi bi-box-seam me-1"></i> Gestión Productos</a>
                    }
                </div>
            </div>

            <div class="d-flex align-items-center gap-4">
                <a asp-controller="Chats" asp-action="Index" class="chat-icon-btn hover-white" title="Mensajes">
                    <i class="bi bi-chat-dots"></i>
                </a>
                
                <a asp-controller="Usuarios" asp-action="Perfil" class="d-flex align-items-center text-decoration-none">
                    <img src="@(!string.IsNullOrEmpty(uFoto) ? uFoto : "/imagenes/placeholder-perfil.png")" class="rounded-circle border border-secondary me-2" style="width: 35px; height: 35px; object-fit: cover;">
                    <span class="text-white-50 small hover-white">
                        Hola, <span class="fw-bold text-white">@uNombre</span>
                        @if (esAdmin) { <span class="text-warning fw-bold ms-1" style="font-size: 0.85rem;"><i class="bi bi-shield-fill text-warning"></i> (Admin)</span> }
                    </span>
                </a>
                
                <form asp-controller="Usuarios" asp-action="Logout" method="post" class="m-0 ms-2">
                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 hover-white">Salir</button>
                </form>
            </div>
        </div>
    </nav>

    @* CONTENEDOR PRINCIPAL PERFIL PUBLICO *@
    <main class="container admin-container">
        <div class="public-profile-card shadow-lg">
            
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary border-opacity-25 pb-4">
                <div>
                    <h2 class="edit-profile-title text-white m-0">Perfil <span style="color: #b388ff;">Público</span></h2>
                    <p class="text-white-50 m-0 mt-1">Conoce más sobre este vendedor y sus productos.</p>
                </div>
                @if (miId == Model.IdUsuario) {
                    <div class="small fw-bold text-warning border border-warning rounded-pill px-3 py-1 bg-warning bg-opacity-10 shadow-sm">
                        <i class="bi bi-eye-fill me-1"></i> MODO VISTA PÚBLICA
                    </div>
                }
            </div>

            <div class="row g-5">
                
                @* 🟢 COLUMNA IZQUIERDA: INFO DEL VENDEDOR 🟢 *@
                <div class="col-lg-4 d-flex flex-column align-items-center text-center border-end border-secondary border-opacity-25 pe-lg-4">
                    
                    @* FOTO *@
                    @if (!string.IsNullOrEmpty(Model.FotoPerfilUrl)) {
                        <img src="@Model.FotoPerfilUrl" alt="@Model.Nombre" class="profile-main-pic">
                    } else {
                        <div class="profile-main-pic d-flex align-items-center justify-content-center bg-dark">
                            <i class="bi bi-person text-white-50 display-1"></i>
                        </div>
                    }

                    <h3 class="fw-bold m-0 text-white">@Model.Nombre</h3>
                    <p class="profile-subtitle-cyan m-0 mt-1"><i class="bi bi-geo-alt-fill text-danger me-1"></i>@(Model.Ciudad ?? "Ubicación no especificada")</p>
                    
                    @* RECUADRO DE DESCRIPCIÓN INTELIGENTE *@
                    @if (!string.IsNullOrEmpty(Model.Descripcion) || miId == Model.IdUsuario)
                    {
                        <div class="bg-dark bg-opacity-50 p-4 rounded-4 border border-secondary border-opacity-25 mt-4 mb-4 text-center w-100">
                            @if (!string.IsNullOrEmpty(Model.Descripcion))
                            {
                                <p class="text-white-50 m-0 fs-6 fst-italic">"@Model.Descripcion"</p>
                            }

                            @if (miId == Model.IdUsuario)
                            {
                                @if (!string.IsNullOrEmpty(Model.Descripcion))
                                {
                                    <hr class="border-secondary opacity-50 mx-auto my-3" style="width: 50%;">
                                }
                                <span class="text-warning small fw-bold">
                                    <i class="bi bi-info-circle me-1"></i> Así es como los demás ven tu biografía.
                                </span>
                            }
                        </div>
                    }

                    @* ZONA DE BOTONES DE CONTACTO (Solo visibles si no es su propio perfil) *@
                    @if (miId != null && miId != Model.IdUsuario)
                    {
                        <div class="d-flex flex-column gap-3 w-100 mt-2">
                            @if (!string.IsNullOrEmpty(Model.Telefono))
                            {
                                <a href="https://wa.me/@Model.Telefono.Replace(" ", "").Replace("+", "")?text=Hola%20@Model.Nombre,%20me%20interesan%20tus%20productos%20en%20ElectroMarket"
                                   target="_blank" class="btn-whatsapp-custom">
                                    <i class="bi bi-whatsapp me-2 fs-5"></i> Contactar por WhatsApp
                                </a>
                            }
                            
                            <a asp-controller="Chats" asp-action="IniciarChat" asp-route-receptorId="@Model.IdUsuario" class="btn-contact-custom">
                                <i class="bi bi-chat-dots-fill me-2 fs-5"></i> Iniciar Chat Interno
                            </a>
                        </div>
                    }
                </div>

                @* 🟢 COLUMNA DERECHA: CATÁLOGO DE PRODUCTOS 🟢 *@
                <div class="col-lg-8 ps-lg-4">
                    <h4 class="form-section-title">Catálogo de <span class="text-cyan-neon">@Model.Nombre</span></h4>
                    
                    @if (productos != null && productos.Any())
                    {
                        <div class="equipment-list">
                            @foreach (var p in productos)
                            {
                                <div class="equipment-item shadow-sm">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(p.ImagenUrl)) {
                                            <img src="@p.ImagenUrl" alt="@p.Nombre" class="equipment-pic border-morado">
                                        } else {
                                            <div class="equipment-pic border-morado d-flex align-items-center justify-content-center bg-dark">
                                                <i class="bi bi-camera text-white-50 fs-3"></i>
                                            </div>
                                        }
                                        
                                        <div>
                                            <h6 class="fw-bold m-0 text-white fs-6">@p.Nombre</h6>
                                            <span class="badge bg-dark border border-secondary border-opacity-50 text-white-50 mt-1">@p.Categoria</span>
                                        </div>
                                    </div>
                                    
                                    <div class="d-flex align-items-center gap-4">
                                        <span class="price-text">$@p.Precio.ToString("N0")</span>
                                        <a asp-controller="Productos" asp-action="Details" asp-route-id="@p.IdProducto" class="btn-view-custom shadow-sm">
                                            Ver Detalles
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-white-50 bg-dark bg-opacity-25 rounded-4 border border-secondary border-opacity-25 mt-4">
                            <i class="bi bi-box-seam display-4 d-block mb-3 opacity-50"></i>
                            <p class="mb-0 fs-5">Este vendedor aún no tiene equipos publicados.</p>
                        </div>
                    }
                </div>

            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>