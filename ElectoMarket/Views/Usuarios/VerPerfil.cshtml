@model ElectoMarket.Models.Usuario
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    Layout = null; // Diseño independiente premium
    ViewData["Title"] = "Perfil de " + Model.Nombre;
    
    //  Lógica original preservada 
    var miId = HttpContextAccessor.HttpContext?.Session.GetInt32("UsuarioId");
    var productos = ViewBag.ProductosPublicos as List<ElectoMarket.Models.Producto>;

    // Variables para la Navbar
    var uNombre = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioNombre") ?? "Usuario";
    var uFoto = HttpContextAccessor.HttpContext?.Session.GetString("UsuarioFoto");
    var miRol = HttpContextAccessor.HttpContext?.Session.GetInt32("UsuarioRol");
    bool esAdmin = miRol == 1;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ElectroMarket</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --bg-dark: #08080a;
            --bg-card: rgba(18, 18, 20, 0.75);
            --border-color: rgba(255, 255, 255, 0.1);
            --text-main: #ffffff;
            --morado: #7c4dff;
            --morado-glow: rgba(124, 77, 255, 0.25);
            --cyan-glow: rgba(0, 210, 255, 0.15);
            --cyan-neon: #00d2ff;
            --verde-neon: #00ff88;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Inter', system-ui, sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        /* --- FONDO TECH --- */
        .tech-bg {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            z-index: -1;
            background-image: radial-gradient(circle at 10% 20%, rgba(124, 77, 255, 0.12) 0%, transparent 40%),
                              radial-gradient(circle at 90% 80%, rgba(0, 210, 255, 0.1) 0%, transparent 40%);
        }

        /*  INTEGRACIÓN DE NUEVOS ESTILOS DE ILUMINACIÓN  */

        /* Subtítulos ("Conoce más sobre este vendedor...") */
        .text-white-50, .opacity-75 {
            color: white !important;
            opacity: 1 !important;
        }

        /* Título de la sección "Catálogo de..." */
        h4, h5 {
            color: white !important;
        }

        /* Mensaje de "Este vendedor aún no tiene equipos publicados" */
        .text-center.py-5, .text-muted {
            color: rgba(255, 255, 255, 0.7) !important;
        }

        /* LA CAJA AMARILLA: Amarillo neón más brillante */
        .text-warning {
            color: #ffcc00 !important;
        }

        /* --- NAVBAR --- */
        .navbar-main { background-color: rgba(10, 10, 12, 0.9); backdrop-filter: blur(15px); border-bottom: 1px solid var(--border-color); padding: 12px 0; }
        .nav-link-tech { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: 0.3s; display: flex; align-items: center; }
        .nav-link-tech:hover { color: var(--cyan-neon); text-shadow: 0 0 10px var(--cyan-neon); }
        .hover-white:hover { color: white !important; transition: 0.2s; }

        /* --- CARDS --- */
        .public-profile-card {
            background: var(--bg-card);
            backdrop-filter: blur(20px);
            border: 2px solid;
            border-image: linear-gradient(135deg, #7c4dff 0%, #00d2ff 100%) 1;
            border-radius: 24px;
            width: 100%; max-width: 1100px; padding: 40px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.7); margin-top: 40px;
        }

        .profile-main-pic {
            width: 160px; height: 160px; border-radius: 50%; object-fit: cover;
            border: 4px solid var(--morado); padding: 6px; box-shadow: 0 0 30px var(--morado-glow);
            margin-bottom: 20px; background: rgba(255,255,255,0.05);
        }

        .equipment-item {
            background: rgba(255,255,255,0.02); border: 1px solid var(--border-color);
            border-radius: 20px; padding: 18px; margin-bottom: 15px; transition: 0.3s;
            display: flex; align-items: center; justify-content: space-between;
        }
        .equipment-item:hover { background: rgba(255,255,255,0.05); border-color: var(--cyan-neon); transform: translateX(10px); }

        .equipment-pic { width: 70px; height: 70px; object-fit: cover; border-radius: 12px; margin-right: 18px; border: 1px solid var(--border-color); }
        .price-text { color: var(--verde-neon); font-weight: 700; font-size: 1.1rem; }

        .btn-contact-custom { background: linear-gradient(135deg, var(--morado), #00d2ff); color: white; border-radius: 12px; padding: 12px; font-weight: 700; text-decoration: none; display: flex; justify-content: center; align-items: center; transition: 0.3s; box-shadow: 0 10px 20px rgba(124, 77, 255, 0.3); }
        .btn-contact-custom:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(124, 77, 255, 0.5); color: white; }
    </style>
</head>
<body>

    <div class="tech-bg"></div>

    @* NAVBAR PREMIUM *@
    <nav class="navbar-main sticky-top shadow-sm z-3">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center text-decoration-none">
                    <img src="/imagenes/Logo/Logo.jpg" alt="Logo" style="height: 40px; width: 40px; border-radius: 50%;">
                    <span class="text-white fw-bold fs-5 ms-2">ElectroMarket</span>
                </a>
                <div class="ms-5 d-flex gap-4">
                    <a asp-controller="Productos" asp-action="Index" class="nav-link-tech"><i class="bi bi-shop me-1"></i> Catálogo</a>
                    @if (esAdmin) { 
                        <a asp-controller="Home" asp-action="Index" class="nav-link-tech"><i class="bi bi-shield-lock me-1"></i> Inicio</a>
                        <a asp-controller="Usuarios" asp-action="ListadoUsuarios" class="nav-link-tech"><i class="bi bi-people me-1"></i> Usuarios</a>
                    }
                </div>
            </div>

            <div class="d-flex align-items-center gap-4">
                <a asp-controller="Chats" asp-action="Index" class="text-white opacity-75 fs-5 hover-white" title="Mensajes"><i class="bi bi-chat-dots"></i></a>
                <a asp-controller="Usuarios" asp-action="Perfil" class="d-flex align-items-center text-decoration-none">
                    <img src="@(!string.IsNullOrEmpty(uFoto) ? uFoto : "/imagenes/placeholder-perfil.png")" class="rounded-circle border border-secondary me-2" style="width: 35px; height: 35px; object-fit: cover;">
                    <span class="small hover-white text-white">Hola, <b>@uNombre</b></span>
                </a>
                <form asp-controller="Usuarios" asp-action="Logout" method="post" class="m-0 ms-2">
                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">Salir</button>
                </form>
            </div>
        </div>
    </nav>

    <main class="container d-flex justify-content-center">
        <div class="public-profile-card">
            
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary border-opacity-25 pb-4">
                <div>
                    <h2 class="text-white m-0 fw-bold">Perfil <span style="color: #b388ff;">Público</span></h2>
                    <p class="text-white-50 m-0 mt-1">Conoce más sobre este vendedor y sus productos.</p>
                </div>
                @if (miId == Model.IdUsuario) {
                    <div class="small fw-bold text-warning border border-warning rounded-pill px-3 py-1 bg-warning bg-opacity-10">
                        <i class="bi bi-eye-fill me-1"></i> MODO VISTA PÚBLICA
                    </div>
                }
            </div>

            <div class="row g-5">
                @* INFO VENDEDOR *@
                <div class="col-lg-4 d-flex flex-column align-items-center text-center border-end border-secondary border-opacity-25">
                    <img src="@(!string.IsNullOrEmpty(Model.FotoPerfilUrl) ? Model.FotoPerfilUrl : "/imagenes/placeholder-perfil.png")" class="profile-main-pic">
                    <h3 class="fw-bold text-white">@Model.Nombre</h3>
                    <p class="text-info"><i class="bi bi-geo-alt-fill text-danger me-1"></i>@(Model.Ciudad ?? "Ubicación no especificada")</p>

                    @if (!string.IsNullOrEmpty(Model.Descripcion) || miId == Model.IdUsuario) {
                        <div class="bg-dark bg-opacity-50 p-4 rounded-4 border border-secondary border-opacity-25 mt-4 w-100">
                            @if (!string.IsNullOrEmpty(Model.Descripcion)) {
                                <p class="text-white m-0 fst-italic">"@Model.Descripcion"</p>
                            }
                            @if (miId == Model.IdUsuario) {
                                <div class="text-warning small fw-bold mt-2"><i class="bi bi-info-circle me-1"></i> Así es como los demás ven tu biografía.</div>
                            }
                        </div>
                    }

                    @if (miId != null && miId != Model.IdUsuario) {
                        <div class="mt-4 w-100">
                            <a asp-controller="Chats" asp-action="IniciarChat" asp-route-receptorId="@Model.IdUsuario" class="btn-contact-custom">
                                <i class="bi bi-chat-dots-fill me-2"></i> Iniciar Chat
                            </a>
                        </div>
                    }
                </div>

                @* CATÁLOGO *@
                <div class="col-lg-8">
                    <h4 class="mb-4 fw-bold">Catálogo de <span class="text-cyan-neon">@Model.Nombre</span></h4>
                    @if (productos != null && productos.Any()) {
                        <div class="equipment-list">
                            @foreach (var p in productos) {
                                <div class="equipment-item shadow-sm">
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(p.ImagenUrl) ? "/imagenes/no-image.png" : p.ImagenUrl)" class="equipment-pic">
                                        <div>
                                            <h6 class="fw-bold m-0 text-white">@p.Nombre</h6>
                                            <span class="badge bg-dark border border-secondary text-white-50 mt-1">@p.Categoria</span>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center gap-4">
                                        <span class="price-text">$@p.Precio.ToString("N0")</span>
                                        <a asp-controller="Productos" asp-action="Details" asp-route-id="@p.IdProducto" class="btn btn-outline-info btn-sm rounded-pill px-3">Ver Detalles</a>
                                    </div>
                                </div>
                            }
                        </div>
                    } else {
                        <div class="text-center py-5 bg-dark bg-opacity-25 rounded-4 border border-secondary border-opacity-25">
                            <i class="bi bi-box-seam display-4 d-block mb-3 opacity-50"></i>
                            <p class="text-white-50">Este vendedor aún no tiene equipos publicados.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>