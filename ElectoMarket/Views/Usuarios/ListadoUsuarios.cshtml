@model IEnumerable<ElectoMarket.Models.Usuario>
@using Microsoft.AspNetCore.Http

@{
    Layout = null; // Diseño independiente premium

    //  DEFINICIÓN DE VARIABLES DE SESIÓN 
    var uId = Context.Session.GetInt32("UsuarioId");
    var uNombre = Context.Session.GetString("UsuarioNombre") ?? "Admin";
    var uFoto = Context.Session.GetString("UsuarioFoto");
    var miRol = Context.Session.GetInt32("UsuarioRol");
    bool esAdmin = miRol == 1;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gestión de Usuarios - ElectroMarket</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
        --bg-dark: #08080a;
        --glass-bg: rgba(18, 18, 22, 0.85);
        --morado-neon: #7c4dff;
        --cyan-neon: #00d2ff;
        --border-glass: rgba(255, 255, 255, 0.1);
        }

        body {
        background-color: var(--bg-dark);
        color: white;
        font-family: 'Inter', system-ui, sans-serif;
        min-height: 100vh;
        margin: 0;
        display: flex;
        flex-direction: column;
        }

        .tech-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
        background-image: radial-gradient(circle at 15% 15%, rgba(124, 77, 255, 0.15) 0%, transparent 45%), radial-gradient(circle at 85% 85%, rgba(0, 210, 255, 0.1) 0%, transparent 45%);
        }

        .navbar-custom {
        background: rgba(10, 10, 12, 0.9);
        backdrop-filter: blur(15px);
        border-bottom: 1px solid var(--border-glass);
        padding: 12px 0;
        }

        .nav-link-tech {
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 500;
        transition: 0.3s;
        display: flex;
        align-items: center;
        }

        .nav-link-tech:hover {
        color: var(--cyan-neon);
        text-shadow: 0 0 10px var(--cyan-neon);
        }

        .hover-white:hover {
        color: white !important;
        transition: 0.2s;
        }

        .admin-container {
        flex-grow: 1;
        padding: 40px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        }

        .glass-panel {
        background: var(--glass-bg);
        backdrop-filter: blur(30px);
        border: 1px solid var(--border-glass);
        border-radius: 24px;
        width: 100%;
        max-width: 1200px;
        padding: 35px;
        box-shadow: 0 30px 60px rgba(0,0,0,0.7);
        position: relative;
        }

        .glass-panel::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(90deg, var(--morado-neon), var(--cyan-neon));
        border-radius: 24px 24px 0 0;
        }

        .search-panel {
        background-color: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 15px;
        padding: 25px;
        }

        .form-control-dark {
        background-color: rgba(0,0,0,0.5) !important;
        border: 1px solid rgba(255,255,255,0.1) !important;
        color: white !important;
        }

        .form-control-dark:focus {
        border-color: var(--cyan-neon) !important;
        box-shadow: 0 0 10px rgba(0, 210, 255, 0.2) !important;
        }

        .table-custom {
        color: white;
        border-collapse: separate;
        border-spacing: 0 12px;
        }

        .table-custom thead th {
        border: none;
        color: var(--cyan-neon);
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1.5px;
        padding: 15px;
        background: #ffffff;
        }

        .table-custom thead th:first-child {
        border-radius: 12px 0 0 12px;
        }

        .table-custom thead th:last-child {
        border-radius: 0 12px 12px 0;
        }

        .table-custom tbody tr {
        background: #ffffff;
        transition: 0.3s;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        border-radius: 12px;
        }

        .table-custom td {
        border: none;
        padding: 15px;
        vertical-align: middle;
        }

        /*  ESTILOS DE ROL CON ICONOS  */
        .badge-admin {
        background: rgba(220, 53, 69, 0.1);
        color: #dc3545;
        border: 1px solid rgba(220, 53, 69, 0.3);
        border-radius: 10px;
        font-weight: 800;
        box-shadow: 0 4px 10px rgba(220, 53, 69, 0.1);
        }

        .badge-client {
        background: rgba(0, 210, 255, 0.1);
        color: #0099cc;
        border: 1px solid rgba(0, 210, 255, 0.3);
        border-radius: 10px;
        font-weight: 800;
        box-shadow: 0 4px 10px rgba(0, 210, 255, 0.1);
        }

        .btn-delete-neon {
        border: 1px solid rgba(220, 53, 69, 0.5);
        color: #dc3545;
        border-radius: 50px;
        padding: 6px 12px;
        transition: 0.3s;
        background: transparent;
        }

        .btn-delete-neon:hover {
        background: #dc3545;
        color: white;
        box-shadow: 0 0 15px rgba(220, 53, 69, 0.5);
        }

        .profile-thumb {
        width: 45px;
        height: 45px;
        object-fit: cover;
        border: 2px solid var(--morado-neon);
        border-radius: 50%;
        }
        
        /*  MODO OSCURO PARA LA LISTA DE USUARIOS  */
        .card, .bg-white, .list-group-item {
        background-color: #161618 !important;
        border: 1px solid #2d2d30 !important;
        color: #FFFFFF !important;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3) !important;
        }
        
        .text-dark, h5, p, span {
        color: #FFFFFF !important;
        }
        
        .text-muted {
        color: #a1a1aa !important;
        }
    </style>
</head>
<body>

    <div class="tech-bg"></div>

    <nav class="navbar-custom z-3">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center text-decoration-none">
                    <img src="/imagenes/Logo/Logo.jpg" alt="Logo" class="me-2" style="height: 40px; width: 40px; border-radius: 50%;">
                    <span class="text-white fw-bold fs-5">ElectroMarket</span>
                </a>
                <div class="ms-5 d-flex gap-4 align-items-center">
                    <a asp-controller="Productos" asp-action="Index" class="nav-link-tech"><i class="bi bi-shop me-1"></i> Catálogo</a>
                    
                    @*  BOTÓN DE TUTORIALES *@
                    <a asp-controller="Guias" asp-action="Index" class="nav-link-tech text-decoration-none d-flex align-items-center" style="color: rgba(255,255,255,0.6); font-size: 0.85rem; font-weight: 500; transition: 0.3s; margin-left: 1.5rem;" onmouseover="this.style.color='#00ff88'; this.style.textShadow='0 0 10px #00ff88';" onmouseout="this.style.color='rgba(255,255,255,0.6)'; this.style.textShadow='none';">
                        <i class="bi bi-play-btn-fill me-1" style="color: #00ff88; text-shadow: 0 0 5px rgba(0,255,136,0.5);"></i> Tutoriales
                    </a>

                    @if (esAdmin)
                    {
                        <a asp-controller="Usuarios" asp-action="ListadoUsuarios" class="text-white text-decoration-none small fw-bold hover-white"><i class="bi bi-people me-1"></i> Gestión Usuarios</a>
                    }
                </div>
            </div>
            <div class="d-flex align-items-center gap-4">
                <a asp-controller="Usuarios" asp-action="Perfil" class="d-flex align-items-center text-decoration-none">
                    <img src="@(!string.IsNullOrEmpty(uFoto) ? uFoto : "/imagenes/placeholder-perfil.png")" class="profile-thumb me-2" style="width: 35px; height: 35px;">
                    <span class="text-white-50 small hover-white">Hola, <span class="fw-bold text-white">@uNombre</span></span>
                </a>
                <form asp-controller="Usuarios" asp-action="Logout" method="post" class="m-0"><button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">Salir</button></form>
            </div>
        </div>
    </nav>

    <div class="admin-container">
        <div class="glass-panel shadow-lg">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold m-0"><i class="bi bi-people-fill text-cyan-neon me-2"></i>Control de <span class="text-cyan-neon">Acceso</span></h2>
                <span class="badge bg-danger px-3 py-2 fw-bold" style="border-radius: 10px; font-size: 0.7rem;"><i class="bi bi-shield-lock-fill me-1"></i> MODO ADMINISTRADOR</span>
            </div>

            @* BUSCADOR *@
            <div class="search-panel mb-4">
                <form asp-action="ListadoUsuarios" method="get">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-5">
                            <label class="small text-white-50 mb-1 fw-bold"><i class="bi bi-search me-1"></i> Nombre de Usuario</label>
                            <input type="text" name="buscarNombre" value="@ViewBag.BuscarNombreActual" class="form-control form-control-dark rounded-3" placeholder="Buscar...">
                        </div>
                        <div class="col-md-4">
                            <label class="small text-white-50 mb-1 fw-bold"><i class="bi bi-funnel me-1"></i> Filtrar por Rango</label>
                            <select name="filtroRol" class="form-select form-control-dark rounded-3">
                                <option value="">Todos los roles</option>
                                <option value="1" selected="@(ViewBag.FiltroRolActual == 1)">Administradores</option>
                                <option value="2" selected="@(ViewBag.FiltroRolActual == 2)">Clientes</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn w-100 fw-bold shadow-lg" style="background: linear-gradient(90deg, var(--cyan-neon), #00b8e6); color: black; border: none; height: 45px; border-radius: 10px;">
                                Aplicar Filtros
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="table-responsive">
                <table class="table table-custom align-middle">
                    <thead>
                        <tr>
                            <th style="background-color: #1c1c1f !important;">Usuario</th>
                            <th style="background-color: #1c1c1f !important;">Contacto</th>
                            <th style="background-color: #1c1c1f !important;">Ciudad</th>
                            <th class="text-center" style="background-color: #1c1c1f !important;">Rango / Rol</th>
                            <th class="text-center" style="background-color: #1c1c1f !important;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td style="background-color: #161618 !important;">
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(item.FotoPerfilUrl) ? "/imagenes/placeholder-perfil.png" : item.FotoPerfilUrl)" class="profile-thumb me-3 shadow-sm" />
                                        <div>
                                            <div class="fw-bold text-white fs-6">@item.Nombre</div>
                                            <small class="text-white-50">ID: #@item.IdUsuario</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-white small fw-semibold" style="background-color: #161618 !important;">@item.Correo</td>
                                <td style="background-color: #161618 !important;"><span class="badge bg-dark px-2 py-1"><i class="bi bi-geo-alt-fill text-danger me-1"></i>@(item.Ciudad ?? "N/A")</span></td>
                                <td class="text-center" style="background-color: #161618 !important;">
                                    @if (item.RolId == 1)
                                    {
                                        <span class="badge badge-admin px-3 py-2">
                                            <i class="bi bi-shield-fill-check me-1"></i> @(item.Rol?.Nombre ?? "Admin")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-client px-3 py-2">
                                            <i class="bi bi-person-fill me-1"></i> @(item.Rol?.Nombre ?? "Cliente")
                                        </span>
                                    }
                                </td>
                                <td class="text-center" style="background-color: #161618 !important;">
                                    @if (item.IdUsuario != uId)
                                    {
                                        <div class="d-flex justify-content-center gap-2">
                                            <button type="button" class="btn btn-outline-info rounded-pill btn-sm px-3 fw-bold" data-bs-toggle="modal" data-bs-target="#modalRol-@item.IdUsuario">
                                                <i class="bi bi-gear-fill me-1"></i> Rol
                                            </button>
                                            <button type="button" class="btn-delete-neon" data-bs-toggle="modal" data-bs-target="#modalEliminar-@item.IdUsuario">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary px-3 py-2 fw-bold" style="border-radius: 8px;"><i class="bi bi-person-circle me-1"></i> Tú</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @*  SECCIÓN DE MODALES (FUERA DE LA TABLA)  *@
    @foreach (var item in Model)
    {
        if (item.IdUsuario != uId)
        {
            <div class="modal fade" id="modalRol-@item.IdUsuario" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content" style="background: var(--glass-bg); border: 1px solid var(--cyan-neon); border-radius: 20px; box-shadow: 0 0 30px rgba(0, 210, 255, 0.2);">
                        <div class="modal-header border-0 pb-0">
                            <h5 class="text-white fw-bold"><i class="bi bi-shield-shaded text-cyan-neon me-2"></i>Modificar Rango</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <form asp-action="ActualizarRol" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="idUsuario" value="@item.IdUsuario" />
                            <div class="modal-body text-center py-4">
                                <p class="text-white-50">Selecciona el nuevo rango para <br><strong class="text-white fs-5">@item.Nombre</strong></p>
                                <select name="nuevoRolId" class="form-select form-control-dark mx-auto mt-3 shadow-sm" style="max-width: 280px; height: 45px; border-radius: 12px;">
                                    @foreach (var rol in (IEnumerable<ElectoMarket.Models.Rol>)ViewBag.ListaRoles)
                                    {
                                        <option value="@rol.IdRol" selected="@(item.RolId == rol.IdRol)">@rol.Nombre</option>
                                    }
                                </select>
                            </div>
                            <div class="modal-footer border-0 d-flex justify-content-center pb-5">
                                <button type="submit" class="btn btn-info rounded-pill px-5 fw-bold shadow-lg" style="height: 45px; background: var(--cyan-neon); color: black; border: none;">
                                    Confirmar Cambio
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="modalEliminar-@item.IdUsuario" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content" style="background: var(--glass-bg); border: 1px solid rgba(220, 53, 69, 0.4); border-radius: 20px;">
                        <div class="modal-header border-0 pb-0"><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
                        <div class="modal-body text-center pb-4">
                            <i class="bi bi-exclamation-octagon-fill text-danger" style="font-size: 4rem; filter: drop-shadow(0 0 10px rgba(220,53,69,0.5));"></i>
                            <h4 class="fw-bold mt-3 text-white">¿Eliminar Usuario?</h4>
                            <p class="text-white-50 px-4">Estás a punto de eliminar permanentemente a <strong>@item.Nombre</strong>.</p>
                        </div>
                        <div class="modal-footer border-0 d-flex justify-content-center pt-0 pb-5 gap-3">
                            <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                            <form asp-controller="Usuarios" asp-action="EliminarConfirmado" asp-route-id="@item.IdUsuario" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold shadow">Sí, Eliminar</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @*  LÓGICA DE ALERTAS AUTOMÁTICAS  *@
    <script>
        document.addEventListener("DOMContentLoaded", function () {
        @if (TempData["Success"] != null)
        {
            <text>
                Swal.fire({
                icon: 'success',
                title: '¡Actualizado!',
                text: '@TempData["Success"]',
                background: '#121216',
                color: '#fff',
                confirmButtonColor: '#00d2ff',
                timer: 3000,
                showConfirmButton: false
                });
            </text>
        }

        @if (TempData["Error"] != null)
        {
            <text>
                Swal.fire({
                icon: 'error',
                title: 'Denegado',
                text: '@TempData["Error"]',
                background: '#121216',
                color: '#fff',
                confirmButtonColor: '#dc3545'
                });
            </text>
        }
        });
    </script>
</body>
</html>