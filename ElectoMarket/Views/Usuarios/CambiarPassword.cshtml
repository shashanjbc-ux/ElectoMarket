@model ElectoMarket.Models.CambiarPasswordViewModel
@using Microsoft.AspNetCore.Http
@{
    Layout = null;
    var uId = Context.Session.GetInt32("UsuarioId");
    var uNombre = Context.Session.GetString("UsuarioNombre") ?? "Usuario";
    var uFoto = Context.Session.GetString("UsuarioFoto");
    var miRol = Context.Session.GetInt32("UsuarioRol");
    bool esAdmin = miRol == 1;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Seguridad - ElectroMarket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root { --bg: #060608; --nav-bg: #0a0a0c; --neon-purple: #7c4dff; --neon-cyan: #00d2ff; }
        body { background-color: var(--bg); color: white; font-family: 'Inter', sans-serif; margin: 0; }

        .nav-tech { background: var(--nav-bg); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 10px 0; position: sticky; top: 0; z-index: 1000; }
        .nav-link-custom { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.9rem; display: flex; align-items: center; gap: 8px; }
        .logo-text { font-weight: 800; font-size: 1.2rem; color: white; text-decoration: none; display: flex; align-items: center; gap: 10px; }
        
        .logo-img { width: 38px; height: 38px; border-radius: 50%; object-fit: cover; border: 1px solid var(--neon-cyan); }
        .profile-img { width: 35px; height: 35px; border-radius: 50%; border: 1px solid var(--neon-cyan); object-fit: cover; cursor: pointer; }

        .security-card { background: #0d0d11; border: 1px solid rgba(255,255,255,0.1); border-radius: 24px; padding: 40px; width: 100%; max-width: 420px; margin: 60px auto; box-shadow: 0 30px 60px rgba(0,0,0,0.5); }
        .input-tech { background: #15151a !important; border: 1px solid rgba(255,255,255,0.1) !important; color: white !important; border-radius: 12px; padding: 12px; width: 100%; }
        .pass-container { position: relative; margin-bottom: 20px; }
        .btn-eye { position: absolute; right: 15px; top: 38px; background: none; border: none; color: var(--neon-cyan); cursor: pointer; opacity: 0.7; }
        .btn-save { background: var(--neon-purple); color: white; border: none; padding: 14px; border-radius: 15px; width: 100%; font-weight: bold; }
    </style>
</head>
<body>

    <nav class="nav-tech">
        <div class="container d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-4">
                <a asp-controller="Home" asp-action="Index" class="logo-text">
                    <img src="/imagenes/Logo/Logo.jpg" class="logo-img" alt="Logo" />
                    ElectroMarket
                </a>
                <a asp-controller="Productos" asp-action="Index" class="nav-link-custom"><i class="bi bi-shop"></i> Catálogo</a>
                @if (esAdmin) {
                    <a asp-controller="Usuarios" asp-action="ListadoUsuarios" class="nav-link-custom"><i class="bi bi-people"></i> Gestión Usuarios</a>
                    <a asp-controller="Productos" asp-action="Gestionar" class="nav-link-custom"><i class="bi bi-box-seam"></i> Gestión Productos</a>
                }
            </div>

            <div class="d-flex align-items-center gap-3">
                <a asp-action="Perfil">
                    <img src="@(string.IsNullOrEmpty(uFoto) ? "/imagenes/default-user.png" : uFoto)" class="profile-img" alt="Perfil">
                </a>
                <div class="small">
                    Hola, <span class="fw-bold">@uNombre</span>
                    @if(esAdmin){ <span style="background:#f1c40f; color:#000; font-size:0.7rem; font-weight:800; padding:2px 8px; border-radius:6px;">ADMIN</span> }
                </div>
                <form asp-action="Logout" method="post" class="m-0">
                    <button type="submit" style="border:1px solid #ff4d4d; color:#ff4d4d; background:none; border-radius:20px; padding:3px 12px; font-size:0.8rem;">Salir</button>
                </form>
            </div>
        </div>
    </nav>

    <div class="security-card">
        <div class="text-center mb-4">
            <i class="bi bi-shield-lock text-info fs-1"></i>
            <h4 class="fw-bold mt-2">Seguridad</h4>
        </div>

        <form asp-action="CambiarPassword" method="post">
            <div class="pass-container">
                <label class="small text-white-50 fw-bold">Contraseña Actual</label>
                <input asp-for="PasswordActual" type="password" id="p1" class="input-tech" placeholder="••••••••">
                <button type="button" class="btn-eye" onclick="toggle('p1', 'e1')"><i id="e1" class="bi bi-eye"></i></button>
                <span asp-validation-for="PasswordActual" class="text-danger small"></span>
            </div>

            <div class="pass-container">
                <label class="small text-white-50 fw-bold">Nueva Contraseña</label>
                <input asp-for="PasswordNueva" type="password" id="p2" class="input-tech" placeholder="Escribe tu nueva clave">
                <button type="button" class="btn-eye" onclick="toggle('p2', 'e2')"><i id="e2" class="bi bi-eye"></i></button>
                <span asp-validation-for="PasswordNueva" class="text-danger small"></span>
            </div>

            <div class="pass-container">
                <label class="small text-white-50 fw-bold">Confirmar Nueva</label>
                <input asp-for="ConfirmarPasswordNueva" type="password" id="p3" class="input-tech" placeholder="Repite la clave">
                <button type="button" class="btn-eye" onclick="toggle('p3', 'e3')"><i id="e3" class="bi bi-eye"></i></button>
                <span asp-validation-for="ConfirmarPasswordNueva" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-save mt-3">Guardar y Cerrar Sesión</button>
        </form>
    </div>

    <script>
        function toggle(id, eid) {
            const i = document.getElementById(id); const e = document.getElementById(eid);
            if (i.type === "password") { i.type = "text"; e.classList.replace("bi-eye", "bi-eye-slash"); }
            else { i.type = "password"; e.classList.replace("bi-eye-slash", "bi-eye"); }
        }
    </script>
</body>
</html>