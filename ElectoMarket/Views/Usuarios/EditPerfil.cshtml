@model ElectoMarket.Models.EditPerfilViewModel
@using Microsoft.AspNetCore.Http

@{
    Layout = null; // DiseГұo independiente premium
    var uId = Context.Session.GetInt32("UsuarioId");
    var uNombre = Context.Session.GetString("UsuarioNombre") ?? "Usuario";
    var uFoto = Context.Session.GetString("UsuarioFoto");
    var uRol = Context.Session.GetInt32("UsuarioRol");
    bool esAdmin = uRol == 1;

    // рҹҹў LГ“GICA INTEGRADA: Limpiamos el +57 al cargar la vista para que no se duplique
    if (!string.IsNullOrEmpty(Model.Telefono) && Model.Telefono.StartsWith("+57"))
    {
        Model.Telefono = Model.Telefono.Replace("+57", "").Trim();
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ConfiguraciГіn de Perfil - ElectroMarket</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
            :root {
                --bg-dark: #08080a;
                --glass-bg: rgba(18, 18, 22, 0.85);
                --morado-neon: #7c4dff;
                --cyan-neon: #00d2ff;
                --border-glass: rgba(255, 255, 255, 0.1);
            }

            body {
                background-color: var(--bg-dark);
                color: white;
                font-family: 'Inter', system-ui, sans-serif;
                min-height: 100vh;
                margin: 0;
                display: flex;
                flex-direction: column;
            }

            /* --- FONDO TECH --- */
            .tech-bg {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                z-index: -1;
                background-image: radial-gradient(circle at 15% 15%, rgba(124, 77, 255, 0.15) 0%, transparent 45%), radial-gradient(circle at 85% 85%, rgba(0, 210, 255, 0.1) 0%, transparent 45%);
            }

                .tech-bg::after {
                    content: "";
                    position: absolute;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0L30 60M0 30L60 30' stroke='rgba(255,255,255,0.02)' stroke-width='0.5'/%3E%3C/svg%3E");
                }

            /* --- NAVBAR --- */
            .navbar-custom {
                background: rgba(10, 10, 12, 0.9);
                backdrop-filter: blur(15px);
                border-bottom: 1px solid var(--border-glass);
                padding: 12px 0;
            }

            .nav-link-tech {
                color: rgba(255,255,255,0.6);
                text-decoration: none;
                font-size: 0.85rem;
                font-weight: 500;
                transition: 0.3s;
                display: flex;
                align-items: center;
            }

                .nav-link-tech:hover {
                    color: var(--cyan-neon);
                    text-shadow: 0 0 10px var(--cyan-neon);
                }

            .hover-white:hover {
                color: white !important;
                transition: 0.2s;
            }

            /* --- CONTENEDOR PRINCIPAL --- */
            .main-container {
                flex-grow: 1;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 40px 20px;
            }

            .glass-panel {
                background: var(--glass-bg);
                backdrop-filter: blur(30px);
                border: 1px solid var(--border-glass);
                border-radius: 24px;
                width: 100%;
                max-width: 800px;
                padding: 45px;
                box-shadow: 0 30px 60px rgba(0,0,0,0.7);
                position: relative;
            }

                .glass-panel::before {
                    content: "";
                    position: absolute;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 3px;
                    background: linear-gradient(90deg, var(--morado-neon), var(--cyan-neon));
                    border-radius: 24px 24px 0 0;
                }

            /* --- FORMULARIOS Y BOTONES --- */
            .form-control-dark {
                background-color: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.1);
                color: white;
                padding: 12px 15px;
                border-radius: 12px;
                transition: 0.3s;
            }

                .form-control-dark:focus {
                    background-color: rgba(0,0,0,0.5);
                    border-color: var(--cyan-neon);
                    box-shadow: 0 0 15px rgba(0, 210, 255, 0.2);
                    color: white;
                }

                .form-control-dark::placeholder {
                    color: rgba(255,255,255,0.3);
                }

            .btn-neon {
                background: linear-gradient(45deg, #6f2dbd, #00d2ff);
                color: white;
                border: none;
                padding: 12px;
                border-radius: 12px;
                font-weight: bold;
                font-size: 1rem;
                transition: 0.3s;
                box-shadow: 0 5px 15px rgba(111, 45, 189, 0.4);
                text-transform: uppercase;
                letter-spacing: 1px;
            }

                .btn-neon:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 8px 25px rgba(0, 210, 255, 0.5);
                    color: white;
                }

            .btn-cancel {
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(255,255,255,0.1);
                color: white;
                padding: 12px;
                border-radius: 12px;
                font-weight: bold;
                transition: 0.3s;
                text-align: center;
                text-decoration: none;
            }

                .btn-cancel:hover {
                    background: rgba(255,255,255,0.1);
                    color: white;
                }

            .link-pass {
                color: var(--cyan-neon);
                text-decoration: none;
                font-size: 0.9rem;
                transition: 0.3s;
            }

                .link-pass:hover {
                    color: white;
                    text-shadow: 0 0 8px var(--cyan-neon);
                }

            /* --- FOTO DE PERFIL --- */
            .foto-preview-container {
                width: 150px;
                height: 150px;
                border-radius: 50%;
                border: 3px solid var(--morado-neon);
                padding: 4px;
                position: relative;
                overflow: hidden;
                margin: 0 auto;
                box-shadow: 0 0 20px rgba(124, 77, 255, 0.3);
                background-color: rgba(255,255,255,0.05);
            }

            .foto-preview {
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: 50%;
            }

            .upload-btn-wrapper {
                position: relative;
                overflow: hidden;
                display: inline-block;
                cursor: pointer;
                margin-top: 15px;
            }

                .upload-btn-wrapper input[type=file] {
                    font-size: 100px;
                    position: absolute;
                    left: 0;
                    top: 0;
                    opacity: 0;
                    cursor: pointer;
                }

            .btn-upload {
                border: 1px solid var(--cyan-neon);
                color: var(--cyan-neon);
                background-color: transparent;
                padding: 8px 20px;
                border-radius: 50px;
                font-size: 0.85rem;
                transition: 0.3s;
            }

            .upload-btn-wrapper:hover .btn-upload {
                background-color: var(--cyan-neon);
                color: black;
                box-shadow: 0 0 10px rgba(0, 210, 255, 0.4);
            }
    </style>
</head>
<body>

    <div class="tech-bg"></div>

    @* рҹҹў NAVBAR UNIFICADA рҹҹў *@
    <nav class="navbar-custom z-3">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center text-decoration-none">
                    <img src="/imagenes/Logo/Logo.jpg" alt="Logo ElectroMarket" class="me-2" style="height: 40px; width: 40px; object-fit: contain; border-radius: 50%; box-shadow: 0 0 10px rgba(124, 77, 255, 0.3);">
                    <span class="text-white fw-bold fs-5">ElectroMarket</span>
                </a>

                <div class="ms-5 d-flex gap-4">
                    <a asp-controller="Productos" asp-action="Index" class="nav-link-tech"><i class="bi bi-shop me-1"></i> CatГЎlogo</a>
                    @if (esAdmin)
                    {
                        <a asp-controller="Usuarios" asp-action="ListadoUsuarios" class="nav-link-tech"><i class="bi bi-people me-1"></i> GestiГіn Usuarios</a>
                        <a asp-controller="Productos" asp-action="Gestionar" class="nav-link-tech"><i class="bi bi-box-seam me-1"></i> GestiГіn Productos</a>
                    }
                </div>
            </div>

            <div class="d-flex align-items-center gap-4">
                <a asp-controller="Chats" asp-action="Index" class="text-white opacity-75 fs-5 hover-white" title="Mensajes">
                    <i class="bi bi-chat-dots"></i>
                </a>

                <a asp-controller="Usuarios" asp-action="Perfil" class="d-flex align-items-center text-decoration-none">
                    <img src="@(!string.IsNullOrEmpty(uFoto) ? uFoto : "/imagenes/placeholder-perfil.png")" class="rounded-circle border border-secondary me-2" style="width: 35px; height: 35px; object-fit: cover;">
                    <span class="text-white-50 small hover-white">
                        Hola, <span class="fw-bold text-white">@uNombre</span>
                        @if (esAdmin)
                        {
                            <span class="badge bg-warning text-dark ms-1" style="font-size: 0.7rem;">ADMIN</span>
                        }
                    </span>
                </a>

                <form asp-controller="Usuarios" asp-action="Logout" method="post" class="m-0 ms-2">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 hover-white">Salir</button>
                </form>
            </div>
        </div>
    </nav>

    <div class="main-container">
        <div class="glass-panel text-center">

            <h2 class="fw-bold mb-4 text-white"><i class="bi bi-gear-fill text-cyan-neon me-2"></i>ConfiguraciГіn de <span class="text-cyan-neon">Perfil</span></h2>

            <form asp-action="EditPerfil" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-bold"></div>

                @* рҹҹў FOTO DE PERFIL *@
                <div class="mb-4">
                    <div class="foto-preview-container">
                        <img id="imgPreview" src="@(!string.IsNullOrEmpty(Model.FotoPerfilUrl) ? Model.FotoPerfilUrl : "/imagenes/placeholder-perfil.png")" class="foto-preview" alt="Foto Actual">
                    </div>
                    <div class="upload-btn-wrapper">
                        <button class="btn-upload" type="button"><i class="bi bi-camera me-1"></i> Cambiar Foto</button>
                        <input type="file" name="NuevaFoto" id="fileFoto" accept="image/*" onchange="previewImage(event)" />
                    </div>
                </div>

                <div class="row g-4 text-start">
                    @* рҹҹў NOMBRE (Sin nГәmeros y mГЎximo 50 caracteres) *@
                    <div class="col-md-6">
                        <label class="small text-white-50 mb-1 fw-bold">Nombre Completo</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark border-secondary text-white-50"><i class="bi bi-person"></i></span>
                            <input asp-for="Nombre"
                                   type="text"
                                   class="form-control form-control-dark"
                                   placeholder="Tu nombre"
                                   maxlength="50"
                                   pattern="^[a-zA-ZГЎГ©ГӯГіГәГҒГүГҚГ“ГҡГұГ‘\s]+$"
                                   oninput="this.value = this.value.replace(/[0-9]/g, '');" />
                        </div>
                        <span asp-validation-for="Nombre" class="text-danger small mt-1 d-block"></span>
                    </div>

                    @* рҹҹў CORREO (Solo .com, sin checkbox) *@
                    <div class="col-md-6">
                        <label class="small text-white-50 mb-1 fw-bold">Correo ElectrГіnico</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark border-secondary text-white-50"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Correo"
                                   type="email"
                                   class="form-control form-control-dark"
                                   placeholder="ejemplo@correo.com"
                                   pattern=".*\.com$"
                                   title="El correo debe terminar en .com"
                                   required />
                        </div>
                        <span asp-validation-for="Correo" class="text-danger small mt-1 d-block"></span>
                    </div>

                    @* рҹҹў TELГүFONO (SE ELIMINГ“ 'REQUIRED' PARA HACERLO OPCIONAL) *@
                    <div class="col-md-6">
                        <label class="small text-white-50 mb-1 fw-bold">TelГ©fono</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark border-secondary text-white fw-bold"><i class="bi bi-phone me-1"></i> +57</span>
                            <input asp-for="Telefono"
                                   type="text"
                                   class="form-control form-control-dark"
                                   placeholder="3000000000 (Opcional)"
                                   maxlength="10"
                                   pattern="^3[0-9]{9}$"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '');" />
                        </div>
                        <span asp-validation-for="Telefono" class="text-danger small mt-1 d-block"></span>
                    </div>

                    @* рҹҹў CIUDAD (Lista desplegable de Colombia) *@
                    <div class="col-md-6">
                        <label class="small text-white-50 mb-1 fw-bold">Ciudad</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark border-secondary text-white-50"><i class="bi bi-geo-alt"></i></span>
                            <select asp-for="Ciudad" class="form-select form-control-dark" style="cursor: pointer;">
                                <option value="" disabled selected>Selecciona tu ciudad...</option>
                                <option value="BogotГЎ">BogotГЎ</option>
                                <option value="MedellГӯn">MedellГӯn</option>
                                <option value="Cali">Cali</option>
                                <option value="Barranquilla">Barranquilla</option>
                                <option value="Cartagena">Cartagena</option>
                                <option value="Bucaramanga">Bucaramanga</option>
                                <option value="CГәcuta">CГәcuta</option>
                                <option value="Pereira">Pereira</option>
                                <option value="Santa Marta">Santa Marta</option>
                                <option value="IbaguГ©">IbaguГ©</option>
                                <option value="Pasto">Pasto</option>
                                <option value="Manizales">Manizales</option>
                                <option value="Neiva">Neiva</option>
                                <option value="Villavicencio">Villavicencio</option>
                                <option value="Armenia">Armenia</option>
                                <option value="Valledupar">Valledupar</option>
                                <option value="MonterГӯa">MonterГӯa</option>
                                <option value="Sincelejo">Sincelejo</option>
                                <option value="PopayГЎn">PopayГЎn</option>
                                <option value="Tunja">Tunja</option>
                                <option value="Riohacha">Riohacha</option>
                                <option value="QuibdГі">QuibdГі</option>
                            </select>
                        </div>
                        <span asp-validation-for="Ciudad" class="text-danger small"></span>
                    </div>

                    @* рҹҹў DESCRIPCIГ“N (MГӯnimo 30 palabras) *@
                    <div class="col-12">
                        <label class="small text-white-50 mb-1 fw-bold">DescripciГіn (Sobre ti)</label>
                        <textarea asp-for="Descripcion"
                                  id="txtDescripcion"
                                  class="form-control form-control-dark"
                                  rows="4"
                                  placeholder="CuГ©ntanos un poco sobre ti (MГӯnimo 30 palabras)..."
                                  oninput="contarPalabras()"></textarea>

                        <div class="d-flex justify-content-between mt-1">
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                            <span id="wordCount" class="small text-white-50 fw-bold">0 / 30 palabras</span>
                        </div>
                    </div>
                </div>

                @* рҹҹў ENLACE CONTRASEГ‘A *@
                <div class="mt-4 mb-4 text-start">
                    <a asp-action="CambiarPassword" class="link-pass"><i class="bi bi-key me-1"></i> ВҝCambiar contraseГұa de seguridad? Haz clic aquГӯ</a>
                </div>

                @* рҹҹў BOTONES *@
                <div class="row g-3 mt-2">
                    <div class="col-md-6">
                        <a asp-action="Perfil" class="btn btn-cancel w-100"><i class="bi bi-x-circle me-1"></i> Cancelar</a>
                    </div>
                    <div class="col-md-6">
                        <button type="submit" class="btn btn-neon w-100"><i class="bi bi-check-circle me-1"></i> Guardar Cambios</button>
                    </div>
                </div>

                <input type="hidden" asp-for="FotoPerfilUrl" />
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // FunciГіn para cambiar la previsualizaciГіn de la foto en tiempo real
        function previewImage(event) {
        var reader = new FileReader();
        reader.onload = function() {
        var output = document.getElementById('imgPreview');
        output.src = reader.result;
        }
        if(event.target.files[0]) {
        reader.readAsDataURL(event.target.files[0]);
        }
        }

        // FunciГіn para contar palabras en tiempo real
        function contarPalabras() {
        var texto = document.getElementById('txtDescripcion').value.trim();
        // Si estГЎ vacГӯo son 0 palabras, si no, cortamos por los espacios
        var cantidadPalabras = texto === "" ? 0 : texto.split(/\s+/).length;
        var contador = document.getElementById('wordCount');

        if (cantidadPalabras > 0 && cantidadPalabras < 30) {
        // Escribiendo pero sin llegar a 30
        contador.innerHTML = `<span class="text-warning">${cantidadPalabras} / 30 palabras (Faltan ${30 - cantidadPalabras})</span>`;
        document.getElementById('txtDescripcion').setCustomValidity("Debes escribir al menos 30 palabras.");
        } else if (cantidadPalabras >= 30) {
        // Meta alcanzada
        contador.innerHTML = `<span class="text-success">${cantidadPalabras} palabras (ВЎMeta alcanzada!) <i class="bi bi-check-circle"></i></span>`;
        document.getElementById('txtDescripcion').setCustomValidity(""); // Quita el error
        } else {
        // VacГӯo (es opcional)
        contador.innerHTML = `0 / 30 palabras`;
        document.getElementById('txtDescripcion').setCustomValidity("");
        }
        }

        // Ejecutar una vez al cargar la pГЎgina por si el usuario ya tenГӯa una descripciГіn guardada
        document.addEventListener("DOMContentLoaded", function() {
        if(document.getElementById('txtDescripcion')) {
        contarPalabras();
        }
        });
    </script>
</body>
</html>