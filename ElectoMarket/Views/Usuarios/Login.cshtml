@model ElectoMarket.Models.LoginViewModel

@{
    Layout = null; // Pantalla completa sin la barra de navegación general
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ingresar - ElectroMarket</title>

    @* Librerías de Estilos *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            background-color: #0f0f10;
            color: #f4f4f4;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        .card-login {
            background-color: #1b1b1d;
            border: 1px solid #333;
            border-radius: 12px;
            padding: 40px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .form-control {
            background-color: #0f0f10;
            border: 1px solid #333;
            color: white;
        }

            .form-control:focus {
                background-color: #0f0f10;
                color: white;
                border-color: #6f2dbd;
                box-shadow: 0 0 0 0.25rem rgba(111, 45, 189, 0.25);
            }

        .btn-morado {
            background-color: #6f2dbd;
            color: white;
            font-weight: bold;
            border: none;
            padding: 12px;
        }

            .btn-morado:hover {
                background-color: #8358d6;
                color: white;
            }
        /* Estilo para el botón del ojo */
        .btn-eye {
            background-color: #0f0f10;
            border: 1px solid #333;
            border-left: none;
            color: #888;
        }

            .btn-eye:hover {
                color: #6f2dbd;
            }

        a.link-primario {
            color: #6f2dbd;
            text-decoration: none;
            font-weight: bold;
        }

            a.link-primario:hover {
                color: #8358d6;
            }
    </style>
</head>
<body>

    <div class="card-login">
        <div class="text-center mb-4">
            <h2 class="fw-bold">Iniciar <span style="color: #6f2dbd;">Sesión</span></h2>
            <p class="text-secondary small">Bienvenido de nuevo a ElectroMarket</p>
        </div>

        @* --- 1. BLOQUE DE MENSAJE DE ÉXITO --- *@
        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success border-0 text-center mb-4" style="background: rgba(0, 255, 136, 0.1); color: #00ff88; font-size: 0.9rem;">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["MensajeExito"]
            </div>
        }

        <form asp-controller="Usuarios" asp-action="Login" method="post">
            @* Mensaje de error general si las credenciales fallan *@
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

            @* Campo: Correo *@
            <div class="mb-3">
                <label asp-for="Correo" class="form-label text-secondary small">Correo Electrónico</label>
                <input asp-for="Correo" class="form-control" placeholder="tu@correo.com" required />
                <span asp-validation-for="Correo" class="text-danger small"></span>
            </div>

            @* Campo: Contraseña con el Ojito *@
            <div class="mb-4">
                <label asp-for="Contrasena" class="form-label text-secondary small">Contraseña</label>
                <div class="input-group">
                    <input asp-for="Contrasena" id="loginPass" type="password" class="form-control border-end-0" placeholder="••••••••" required />
                    <button class="btn btn-eye" type="button" onclick="toggleLoginPassword()">
                        <i id="loginEyeIcon" class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Contrasena" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-morado w-100 py-2 shadow-sm">Entrar</button>

            @* --- 2. LINK DE RECUPERACIÓN --- *@
            <div class="text-center mt-3">
                <a asp-action="SolicitarRecuperacion" class="text-white-50 small text-decoration-none" style="transition: 0.3s;" onmouseover="this.style.color='#7c4dff'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">¿Olvidaste tu contraseña?</a>
            </div>

            <div class="text-center mt-4">
                <p class="small text-secondary mb-1">¿No tienes cuenta? <a asp-action="Register" class="link-primario">Regístrate aquí</a></p>
                <p class="small mt-2"><a asp-controller="Home" asp-action="Index" class="text-secondary fw-normal">Volver al inicio</a></p>
            </div>
        </form>
    </div>

    @* Script para la magia del ojo *@
    <script>
        function toggleLoginPassword() {
            const input = document.getElementById('loginPass');
            const icon = document.getElementById('loginEyeIcon');

            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            }
        }
    </script>

    @* Scripts de validación del lado del cliente *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>
