@model ElectoMarket.Models.LoginViewModel

@{
    ViewData["Title"] = "Acceso";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acceso - ElectroMarket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { 
            background-color: #0f0f10; 
            color: #f4f4f4; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            height: 100vh; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .card-custom { 
            background-color: #1b1b1d; 
            border: 1px solid #333; 
            border-radius: 12px; 
            padding: 40px; 
            width: 100%; 
            max-width: 400px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
        .form-control { 
            background-color: #0f0f10; 
            border: 1px solid #333; 
            color: white; 
        }
        .form-control:focus { 
            border-color: #6f2dbd; 
            box-shadow: 0 0 0 0.25rem rgba(111, 45, 189, 0.25); 
            background-color: #0f0f10; 
            color: white; 
        }
        .btn-morado { 
            background-color: #6f2dbd; 
            color: white; 
            font-weight: 600;
            border: none; 
        }
        .btn-morado:hover { 
            background-color: #8358d6; 
            color: white;
        }
    </style>
</head>
<body>
    <div class="card-custom">
        <div class="text-center mb-4">
            <h3 class="fw-bold">Ingresar a <span style="color: #6f2dbd;">ElectroMarket</span></h3>
        </div>
        
        <form asp-action="Login">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="mb-3">
                <label asp-for="Correo" class="form-label text-secondary small">Correo Electrónico</label>
                <input asp-for="Correo" class="form-control" placeholder="tu@correo.com" />
                <span asp-validation-for="Correo" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Contrasena" class="form-label text-secondary small">Contraseña</label>
                <input asp-for="Contrasena" type="password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Contrasena" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-morado w-100 py-2 mb-3">Ingresar</button>
            
            <div class="text-center">
                <a href="/Home/Default" class="small text-secondary text-decoration-none">Volver al inicio</a>
            </div>
        </form>
    </div>
</body>
</html>
