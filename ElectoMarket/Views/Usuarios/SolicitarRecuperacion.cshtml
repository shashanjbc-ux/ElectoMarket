@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recuperar - ElectroMarket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body {
            background-color: #0f0f10;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            font-family: 'Inter', sans-serif;
        }

        .card-custom {
            background: #1b1b1d;
            padding: 40px;
            border-radius: 20px;
            width: 100%;
            max-width: 400px;
            border: 1px solid #333;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }

        .btn-morado {
            background: #6f2dbd;
            color: white;
            border-radius: 12px;
            border: none;
            padding: 12px;
            font-weight: bold;
            width: 100%;
            transition: 0.3s;
        }

            .btn-morado:hover {
                background: #8358d6;
                transform: translateY(-2px);
            }

        .form-control {
            background: #0f0f10;
            border: 1px solid #333;
            color: white;
            padding: 12px;
        }

            .form-control:focus {
                background: #0f0f10;
                color: white;
                border-color: #6f2dbd;
                box-shadow: none;
            }
    </style>
</head>
<body>
    <div class="card-custom text-center">
        <div class="mb-4">
            <i class="bi bi-shield-lock-fill" style="font-size: 3rem; color: #6f2dbd;"></i>
        </div>
        <h2 class="fw-bold mb-2">Recuperar <span style="color:#6f2dbd">Acceso</span></h2>
        <p class="text-secondary small mb-4">Ingresa tu correo para buscar tu cuenta y restablecer tu clave</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger small border-0 mb-3" style="background: rgba(255, 59, 48, 0.1); color: #ff3b30;">
                <i class="bi bi-exclamation-circle me-1"></i> @ViewBag.Error
            </div>
        }

        <form asp-action="SolicitarRecuperacion" method="post">
            <div class="mb-4 text-start">
                <label class="form-label text-secondary small">Correo Electrónico</label>
                <input type="email" name="correo" class="form-control" placeholder="correo@ejemplo.com" required>
            </div>
            <button type="submit" class="btn btn-morado shadow-sm">Continuar</button>
        </form>

        <div class="mt-4">
            <a asp-action="Login" class="text-secondary small text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i> Volver al inicio
            </a>
        </div>
    </div>
</body>
</html>
